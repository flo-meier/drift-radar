  .scan-strip-label { font-family: var(--sans); font-size: 11px; font-weight: 500; color: var(--ink-mute); letter-spacing: 0.08em; text-transform: uppercase; }
  .scan-strip-val { font-size: 12px; font-weight: 500; color: var(--ink); }
