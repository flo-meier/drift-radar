  .strip-axis { stroke: var(--ink); stroke-width: 1; }
  .strip-guide line { stroke: var(--rule-strong); stroke-width: 1; stroke-dasharray: 2 4; }
  .strip-guide-label { font-family: var(--mono); font-size: 11px; fill: var(--ink-soft); }
  .strip-guide-label-soft { font-family: var(--sans); font-size: 10px; fill: var(--ink-mute); letter-spacing: 0.04em; text-transform: uppercase; }
  .strip-axis-title { font-family: var(--sans); font-size: 10px; fill: var(--ink-mute); letter-spacing: 0.08em; text-transform: uppercase; }
  .strip-axis-title-y { letter-spacing: 0.08em; }
  .strip-rank-label { font-family: var(--mono); font-size: 10px; fill: var(--ink-mute); }
  .strip-bar { cursor: pointer; transition: opacity 140ms ease; opacity: 0.94; }
  .strip-bar:hover, .strip-bar.is-active { opacity: 1; stroke: var(--ink); stroke-width: 1.5; }
  .strip-bar-drift { fill: var(--drift); }
  .strip-bar-ownonly { fill: var(--drift); opacity: 0.78; }
  .strip-bar-full { fill: var(--ink-mute); opacity: 0.7; }
  .strip-bar-active { fill: var(--rule-strong); opacity: 0.6; }

  .strip-tooltip { position: absolute; pointer-events: none; background: var(--ink); border: 1px solid var(--ink); padding: 14px 18px 12px; max-width: 340px; color: var(--bg); font-family: var(--sans); opacity: 0; transition: opacity 140ms ease; transform: translate(-50%, calc(-100% - 14px)); z-index: 10; box-shadow: 0 8px 24px rgba(26, 22, 20, 0.28); }
  .strip-tooltip.is-visible { opacity: 1; pointer-events: auto; }
  .strip-tooltip::after { content: ''; position: absolute; left: 50%; bottom: -6px; width: 10px; height: 10px; background: var(--ink); border-right: 1px solid var(--ink); border-bottom: 1px solid var(--ink); transform: translateX(-50%) rotate(45deg); }
  .strip-tooltip-prompt { font-family: var(--serif); font-style: italic; font-size: 14px; line-height: 1.45; color: var(--bg); }
  .strip-tooltip-meta { font-family: var(--mono); font-size: 11px; color: rgba(247, 244, 238, 0.78); margin-top: 8px; line-height: 1.5; letter-spacing: 0.01em; }
  .strip-tooltip-link { display: inline-block; margin-top: 10px; font-family: var(--sans); font-size: 11px; color: var(--drift); text-decoration: none; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; border-bottom: 1px solid currentColor; padding-bottom: 1px; pointer-events: auto; }
  .strip-tooltip-link:hover { color: var(--bg); }
  .strip-tooltip-link[hidden] { display: none; }

  .strip-legend { display: flex; justify-content: center; flex-wrap: wrap; gap: 22px; margin-top: 28px; font-family: var(--sans); font-size: 13px; color: var(--ink-soft); }
  .strip-legend-item { display: inline-flex; align-items: center; gap: 8px; }
  .strip-legend-swatch { width: 14px; height: 14px; display: inline-block; border: 1px solid var(--rule-strong); }
  .strip-legend-swatch-drift { background: var(--drift); border-color: var(--drift); }
  .strip-legend-swatch-ownonly { background: var(--drift); border-color: var(--drift); opacity: 0.78; }
  .strip-legend-swatch-full { background: var(--ink-mute); border-color: var(--ink-mute); opacity: 0.7; }
  .strip-legend-swatch-active { background: var(--rule-strong); border-color: var(--rule-strong); opacity: 0.6; }
  .strip-legend-count { color: var(--ink-mute); font-size: 11px; font-weight: 600; }

  @media (max-width: 720px) {
    .strip-section { padding: 48px 0 40px; }
    .strip-wrap { padding: 0 6px; }
    .strip-tooltip { max-width: 260px; font-size: 12.5px; padding: 10px 14px; }
    .strip-guide-label-soft { display: none; }
  }

  /* Legend box – shared across heatmap + deep-dive sections */
  .legend-box { margin: 36px 0 32px; background: var(--bg-alt); border: 1px solid var(--rule); padding: 20px 24px 16px; }
  .legend-box-dd { margin-bottom: 48px; }
  .legend-title { font-family: var(--sans); font-size: 11px; font-weight: 600; color: var(--ink-mute); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 14px; }
  .legend-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px 28px; }
  .legend-grid-dd { grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
  .legend-item { display: flex; gap: 12px; align-items: flex-start; font-size: 13px; line-height: 1.45; }
  .legend-item strong { display: block; color: var(--ink); font-size: 13px; font-weight: 600; margin-bottom: 2px; }
  .legend-item span { color: var(--ink-soft); font-size: 12.5px; }
  .legend-swatch { flex-shrink: 0; width: 36px; height: 22px; display: inline-flex; align-items: center; justify-content: center; font-family: var(--mono); font-weight: 700; font-size: 11px; border: 1px solid var(--rule-strong); background: var(--bg); color: var(--ink); }
  .legend-swatch-drift { background: var(--bg); color: var(--drift); border-color: var(--drift); }
  .legend-swatch-bar { background: linear-gradient(to right, var(--drift) 60%, var(--bg-deep) 60%); border-color: var(--rule-strong); color: transparent; }
  .legend-swatch-ownonly { background: var(--competitor-soft); border-color: var(--competitor); color: var(--competitor); font-style: italic; }
  .legend-swatch-ownonly::before { content: 'own-only'; font-size: 9px; font-weight: 600; letter-spacing: 0.04em; }
  .legend-swatch-fullsilence { background: var(--bg-deep); border-color: var(--ink-mute); color: var(--ink-mute); }
  .legend-swatch-fullsilence::before { content: 'silent'; font-size: 9px; font-weight: 600; letter-spacing: 0.04em; }
  .legend-swatch-deepdive { background: var(--drift); color: var(--bg); border-color: var(--drift); font-size: 13px; }
  .legend-swatch-ci { background: var(--bg); border-color: var(--ink-mute); color: var(--ink); font-size: 10px; letter-spacing: -0.05em; }
  .legend-swatch-silent { background: var(--bg-deep); color: var(--ink-mute); border-color: var(--rule-strong); }
  .legend-swatch-hero { background: var(--own); color: var(--bg); border-color: var(--own); }

  .heatmap-row.has-deepdive { cursor: pointer; position: relative; }
  .heatmap-row.has-deepdive::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: transparent; transition: background 140ms ease; }
  .heatmap-row.has-deepdive:hover { background: var(--drift-soft); }
  .heatmap-row.has-deepdive:hover::before { background: var(--drift); }
  .heatmap-row.has-deepdive:hover .heatmap-score { color: var(--drift); }
  .deepdive-link { font-family: var(--sans); font-weight: 600; font-size: 11px; color: var(--bg); background: var(--drift); text-transform: uppercase; letter-spacing: 0.08em; text-decoration: none; padding: 5px 10px; border: 1px solid var(--drift); border-radius: 0; white-space: nowrap; }
  .deepdive-link:hover { background: var(--ink); border-color: var(--ink); color: var(--bg); text-decoration: none; }

  /* Filter visibility rules */
  body.filter-drifting .heatmap-row:not(.is-drifting) { display: none; }
  body.filter-own-only .heatmap-row:not(.has-competitors) { display: none; }
  body.filter-full-silence .heatmap-row:not(.is-full-silence) { display: none; }
  body.filter-has-deepdive .heatmap-row:not(.has-deepdive) { display: none; }
  .heatmap { border-top: 1px solid var(--ink); border-bottom: 1px solid var(--ink); }
  .heatmap-head { display: grid; grid-template-columns: 80px repeat(3, 150px) 1fr; border-bottom: 1px solid var(--rule-strong); background: var(--bg-alt); }
  .heatmap-head-cell { padding: 14px 16px; font-family: var(--sans); font-size: 11px; font-weight: 600; color: var(--ink-soft); letter-spacing: 0.12em; text-transform: uppercase; }
  .heatmap-score-col { text-align: right; padding-right: 20px; }
  .heatmap-prompt-col { padding-left: 20px; }
  .heatmap-row { display: grid; grid-template-columns: 80px repeat(3, 150px) 1fr; border-bottom: 1px solid var(--rule); transition: background 120ms ease; }
  .heatmap-row:last-child { border-bottom: none; }
  .heatmap-row:hover { background: var(--bg-alt); }
  .heatmap-row.has-competitors .heatmap-score { color: var(--drift); }
  .heatmap-cell { padding: 18px 16px; display: flex; align-items: center; }
  .heatmap-score { font-family: var(--mono); font-weight: 700; font-size: 16px; color: var(--ink); justify-content: flex-end; padding-right: 20px; }
  .heatmap-bar-cell { flex-direction: column; align-items: stretch; justify-content: center; gap: 6px; padding: 18px 14px; }
  .heatmap-bar-track { height: 8px; background: var(--bg-alt); border: 1px solid var(--rule); position: relative; }
  .heatmap-bar-fill { position: absolute; top: 0; left: 0; bottom: 0; background: var(--drift); opacity: 0.85; }
  .has-competitors .heatmap-bar-fill { background: var(--drift); }
  .heatmap-row.is-full-silence .heatmap-bar-fill { background: var(--ink-mute); }
  .heatmap-bar-val { font-family: var(--mono); font-size: 11px; color: var(--ink-soft); letter-spacing: 0.02em; }
  .heatmap-bar-engine { display: none; }
  .heatmap-prompt { flex-direction: column; align-items: flex-start; gap: 6px; padding: 18px 20px; }

  @media (max-width: 720px) {
    .heatmap-head { display: none; }
    .heatmap-row {
      grid-template-columns: 56px 1fr;
      grid-template-areas:
        "score prompt"
        "bar1 bar1"
        "bar2 bar2"
        "bar3 bar3";
      row-gap: 2px;
      padding-bottom: 14px;
    }
    .heatmap-row > .heatmap-score { grid-area: score; padding: 14px 6px 4px 16px; justify-content: flex-start; font-size: 15px; }
    .heatmap-row > .heatmap-prompt { grid-area: prompt; padding: 14px 16px 4px 0; }
    .heatmap-row > .heatmap-bar-cell:nth-child(2) { grid-area: bar1; }
    .heatmap-row > .heatmap-bar-cell:nth-child(3) { grid-area: bar2; }
    .heatmap-row > .heatmap-bar-cell:nth-child(4) { grid-area: bar3; }
    .heatmap-row .heatmap-bar-cell {
      flex-direction: row;
      align-items: center;
      gap: 10px;
      padding: 2px 16px 2px 16px;
      min-height: 22px;
    }
    .heatmap-row .heatmap-bar-engine {
      display: inline-block;
      font-family: var(--sans);
      font-size: 10px;
      font-weight: 600;
      color: var(--ink-soft);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      min-width: 88px;
      flex-shrink: 0;
    }
    .heatmap-row .heatmap-bar-track { flex: 1; }
    .heatmap-row .heatmap-bar-val { min-width: 36px; text-align: right; flex-shrink: 0; }
    .prompt-text { font-size: 15px; }
    .prompt-meta { font-size: 11px; }
  }

  .prompt-text { font-family: var(--serif); font-size: 17px; line-height: 1.35; color: var(--ink); }
  .prompt-meta { font-family: var(--sans); font-size: 12px; color: var(--ink-mute); letter-spacing: 0.02em; }
  .prompt-meta em { color: var(--ink-soft); }

  .deepdive-section { padding-top: 96px; padding-bottom: 96px; }
  .deepdive { padding: 56px 0; border-top: 1px solid var(--rule); }
  .deepdive:first-of-type { border-top: 1px solid var(--ink); }
  .deepdive:last-of-type { border-bottom: 1px solid var(--ink); }
  .deepdive-header { display: grid; grid-template-columns: 300px 1fr; gap: 40px; margin-bottom: 40px; align-items: start; }
  @media (max-width: 900px) { .deepdive-header { grid-template-columns: 1fr; gap: 16px; } }
  .deepdive-mobile-toggle { display: none; }
  @media (max-width: 720px) {
    .deepdive-mobile-toggle {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-top: 18px;
      padding: 10px 16px;
      font-family: var(--sans);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink);
      background: var(--bg-alt);
      border: 1px solid var(--rule-strong);
      cursor: pointer;
      transition: background 120ms ease, color 120ms ease;
    }
    .deepdive-mobile-toggle:hover { background: var(--drift-soft); }
    .deepdive-mobile-toggle-chev { transition: transform 160ms ease; }
    .deepdive.is-expanded .deepdive-mobile-toggle-chev { transform: rotate(180deg); }
    .deepdive.is-expanded .deepdive-mobile-toggle-label::before { content: 'Collapse'; }
    .deepdive.is-expanded .deepdive-mobile-toggle-label { font-size: 0; }
    .deepdive.is-expanded .deepdive-mobile-toggle-label::before { font-size: 12px; }
    /* Collapse non-first deep-dive bodies by default on mobile */
    .deepdive[data-dd-index]:not([data-dd-index="0"]):not(.is-expanded) .deepdive-body { display: none; }
    .deepdive[data-dd-index]:not([data-dd-index="0"]):not(.is-expanded) { padding: 28px 0; }
    .deepdive[data-dd-index]:not([data-dd-index="0"]):not(.is-expanded) .deepdive-header { margin-bottom: 0; }
  }
  .deepdive-score-block { padding-top: 4px; }
  .deepdive-score-block .typo-number { font-size: clamp(72px, 8.4vw, 108px); line-height: 0.92; }
  .deepdive-prompt { font-style: italic; font-size: clamp(24px, 3vw, 32px); line-height: 1.3; font-weight: 500; }
  /* Wilson-CI band per deep-dive engine */
  .deepdive-ci { display: flex; flex-direction: column; gap: 4px; margin-top: -4px; }
  .deepdive-ci-track { position: relative; height: 10px; background: linear-gradient(to right, var(--rule) 0 100%); border-radius: 2px; }
  .deepdive-ci-band { position: absolute; top: 2px; bottom: 2px; background: var(--drift-soft); border-left: 1px solid var(--drift); border-right: 1px solid var(--drift); }
  .deepdive-ci-point { position: absolute; top: -2px; bottom: -2px; width: 2px; background: var(--drift); transform: translateX(-1px); }
  .deepdive-col.is-hero .deepdive-ci-band { background: rgba(62, 92, 46, 0.18); border-color: var(--own); }
  .deepdive-col.is-hero .deepdive-ci-point { background: var(--own); }
  .deepdive-ci-label { font-size: 10px; color: var(--ink-mute); letter-spacing: 0.04em; }

  .deepdive-columns { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  @media (max-width: 900px) { .deepdive-columns { grid-template-columns: 1fr; gap: 24px; } }
  .deepdive-col { padding-top: 20px; border-top: 2px solid var(--ink); display: flex; flex-direction: column; gap: 16px; min-height: 280px; }
  .deepdive-col.is-hero { border-top-color: var(--own); }
  .deepdive-col.is-silent { border-top-color: var(--rule-strong); }
  .deepdive-col.is-nodata { border-top-color: var(--rule); }
  .deepdive-col-head { display: flex; justify-content: space-between; align-items: baseline; padding-bottom: 12px; border-bottom: 1px solid var(--rule); }
  .deepdive-engine { font-family: var(--serif); font-weight: 700; font-size: 16px; color: var(--ink); letter-spacing: 0.02em; }
  .deepdive-col.is-hero .deepdive-engine { color: var(--own); }
  .deepdive-vis { font-size: 15px; font-weight: 500; color: var(--ink-soft); }
  .deepdive-col.is-hero .deepdive-vis { color: var(--own); font-weight: 700; }
  .deepdive-brands { }
  .deepdive-brand-list { margin-top: 8px; display: flex; flex-direction: column; gap: 3px; font-family: var(--serif); font-size: 15px; }
  .brand-name.is-own { color: var(--own); font-weight: 700; }
  .brand-name.is-competitor { color: var(--competitor); font-weight: 500; }
  .deepdive-quote { margin: 12px 0 0; padding: 0; padding-left: 14px; border-left: 2px solid var(--rule-strong); font-family: var(--serif); font-style: italic; font-size: 14px; line-height: 1.5; color: var(--ink-soft); white-space: pre-wrap; }
  .deepdive-col.is-hero .deepdive-quote { border-left-color: var(--own); }

  /* Narrative Matrix (Metrik 3 – Claim-Type Distribution) */
  .narrative-matrix { margin: 8px 0 40px; padding: 28px 0 32px; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
  .narrative-matrix-head { display: flex; justify-content: space-between; align-items: baseline; gap: 24px; flex-wrap: wrap; margin-bottom: 20px; }
  .narrative-matrix-legend { display: flex; gap: 14px; flex-wrap: wrap; }
  .narrative-matrix-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  @media (max-width: 900px) { .narrative-matrix-grid { grid-template-columns: 1fr; gap: 20px; } }
  .narrative-matrix-col { display: flex; flex-direction: column; gap: 10px; }
  .narrative-matrix-engine { font-family: var(--serif); font-weight: 600; font-size: 14px; color: var(--ink-soft); letter-spacing: 0.02em; }
  .narrative-matrix-bar { display: flex; height: 14px; background: var(--bg-alt); border: 1px solid var(--rule); overflow: hidden; }
  .narrative-matrix-bar .mono { padding: 0 10px; align-self: center; font-size: 11px; }
  .narrative-matrix-seg { display: block; height: 100%; min-width: 2px; }
  .narrative-matrix-counts { display: flex; flex-wrap: wrap; gap: 12px 16px; font-size: 12px; color: var(--ink-mute); }
  .narrative-matrix-count { letter-spacing: 0.02em; }
  .narrative-matrix-count .text-type-brand { color: var(--drift); font-weight: 600; }
  .narrative-matrix-count .text-type-substance { color: var(--own); font-weight: 600; }
  .narrative-matrix-count .text-type-function { color: var(--ink); font-weight: 600; }
  .narrative-matrix-count .text-type-condition { color: var(--competitor); font-weight: 600; }
  .narrative-matrix-count .text-type-criterion { color: var(--warn); font-weight: 600; }

  /* Claim chips (legend + matrix segments) */
  .claim-chip { display: inline-flex; align-items: center; gap: 6px; font-family: var(--sans); font-size: 11px; font-weight: 500; color: var(--ink-soft); letter-spacing: 0.04em; text-transform: uppercase; }
  .claim-chip .claim-chip-dot { width: 9px; height: 9px; display: inline-block; border-radius: 50%; }
  .claim-chip-brand .claim-chip-dot, .narrative-matrix-seg.claim-chip-brand { background: var(--drift); }
  .claim-chip-substance .claim-chip-dot, .narrative-matrix-seg.claim-chip-substance { background: var(--own); }
  .claim-chip-function .claim-chip-dot, .narrative-matrix-seg.claim-chip-function { background: var(--ink); }
  .claim-chip-condition .claim-chip-dot, .narrative-matrix-seg.claim-chip-condition { background: var(--competitor); }
  .claim-chip-criterion .claim-chip-dot, .narrative-matrix-seg.claim-chip-criterion { background: var(--warn); }

  /* Per-column claim list */
  .deepdive-claims { margin-top: 4px; }
  .claim-list { list-style: none; margin: 8px 0 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .claim { display: grid; grid-template-columns: 72px 1fr; gap: 10px; font-size: 13.5px; line-height: 1.4; padding-top: 6px; border-top: 1px dashed var(--rule); }
  .claim:first-child { border-top: none; padding-top: 0; }
  .claim-label { font-family: var(--sans); font-size: 10px; font-weight: 600; color: var(--ink-mute); letter-spacing: 0.1em; text-transform: uppercase; padding-top: 3px; }
  .claim-text { font-family: var(--serif); color: var(--ink); font-size: 14.5px; }
  .claim-type-substance .claim-label { color: var(--own); }
  .claim-type-substance .claim-text { color: var(--own); font-weight: 600; }
  .claim-type-function .claim-label { color: var(--ink-soft); }
  .claim-type-condition .claim-label { color: var(--competitor); }
  .claim-type-condition .claim-text { font-style: italic; color: var(--ink-soft); }
  .claim-type-criterion .claim-label { color: var(--warn); }
  .claim-type-criterion .claim-text { font-style: italic; color: var(--ink-soft); }
  .claim-type-brand .claim-label { color: var(--drift); }
  .claim-type-brand.claim-brand-own .claim-text { color: var(--own); font-weight: 700; }
  .claim-type-brand.claim-brand-competitor .claim-text { color: var(--competitor); font-weight: 500; }
  .claim-type-brand.claim-brand-unknown .claim-text { color: var(--drift); font-style: italic; }
  .claim-type-brand.claim-brand-unknown .claim-text::after { content: ' · untracked'; font-family: var(--sans); font-size: 10px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--drift); opacity: 0.7; }
  /* Brand hit within non-brand claim (e.g. substance claim mentioning Pferdegold) */
  .claim.claim-brandhit-own .claim-text { color: var(--own); font-weight: 600; }
  .claim.claim-brandhit-competitor .claim-text { color: var(--competitor); font-weight: 500; }

  .competitors-section { padding: 96px 0; background: var(--bg-alt); }
  .competitor-table { border-top: 1px solid var(--ink); border-bottom: 1px solid var(--ink); }
  .competitor-head { display: grid; grid-template-columns: 1.5fr 80px 180px 1fr; padding: 14px 0; border-bottom: 1px solid var(--rule-strong); font-family: var(--sans); font-size: 11px; font-weight: 600; color: var(--ink-soft); letter-spacing: 0.12em; text-transform: uppercase; }
  .competitor-row { display: grid; grid-template-columns: 1.5fr 80px 180px 1fr; align-items: center; padding: 20px 0; border-bottom: 1px solid var(--rule); }
  .competitor-row:last-child { border-bottom: none; }
  .competitor-row.own-row { background: var(--own-soft); margin: 0 -16px; padding: 20px 16px; border-bottom: 1px solid var(--rule); }
  .competitor-name { font-size: 22px; font-weight: 600; color: var(--ink); }
  .competitor-row.own-row .competitor-name { color: var(--own); }
  .competitor-bar { display: flex; align-items: center; }
  .competitor-bar-track { flex: 1; height: 6px; background: var(--bg-deep); border: 1px solid var(--rule); }
  .competitor-bar-fill { height: 100%; background: var(--competitor); opacity: 0.9; }
  .competitor-bar-fill.own-fill { background: var(--own); }
  @media (max-width: 900px) {
    .competitor-head, .competitor-row { grid-template-columns: 1fr 1fr; gap: 8px; }
    .competitor-head > *:nth-child(3), .competitor-row > *:nth-child(3) { display: none; }
  }

  .ownonly-section { padding: 96px 0; }
  .stanza-list { display: flex; flex-direction: column; }
  .stanza { padding: 32px 0; border-top: 1px solid var(--rule); }
  .stanza:first-child { border-top: 1px solid var(--ink); }
  .stanza:last-child { border-bottom: 1px solid var(--ink); }
  .stanza-prompt { font-family: var(--serif); font-style: italic; font-size: 22px; line-height: 1.35; font-weight: 500; color: var(--ink); }
  .stanza-meta { font-size: 13px; color: var(--ink-mute); margin-top: 6px; font-family: var(--sans); letter-spacing: 0.02em; }
  .stanza-cited { margin-top: 14px; font-size: 15px; font-family: var(--sans); }

  .full-silence-section { padding: 96px 0; background: var(--bg-alt); }
  .plain-list { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--ink); border-bottom: 1px solid var(--ink); }
  .plain-list li { padding: 16px 0; border-bottom: 1px solid var(--rule); }
  .plain-list li:last-child { border-bottom: none; }

  .methodology { padding: 96px 0; }
  .methodology-body { display: grid; grid-template-columns: 1fr 1fr; gap: 48px 64px; }
  @media (max-width: 900px) { .methodology-body { grid-template-columns: 1fr; gap: 32px; } }
  .method-block { padding: 24px 0; border-top: 1px solid var(--rule); }
  .method-block:nth-child(-n+2) { border-top: 1px solid var(--ink); }
  .method-block p { color: var(--ink-soft); font-size: 15px; line-height: 1.6; }

  /* Peec-native actions grid */
  .peec-actions-section { padding: 96px 0; }
  .peec-actions-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-top: 40px; }
  @media (max-width: 900px) { .peec-actions-grid { grid-template-columns: 1fr; gap: 20px; } }
  .peec-action-card { padding: 28px 30px; border-left: 3px solid var(--own); background: var(--bg-alt); display: flex; flex-direction: column; }
  .peec-action-meta { display: flex; justify-content: space-between; align-items: baseline; gap: 20px; font-family: var(--sans); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-mute); }
  .peec-action-scope { font-weight: 600; color: var(--own); }
  .peec-action-score { font-size: 11px; letter-spacing: 0.02em; text-transform: none; color: var(--ink-soft); font-family: var(--mono); }
  .peec-action-text { font-family: var(--serif); font-size: 17px; line-height: 1.5; color: var(--ink); margin-top: 16px; flex: 1; }
  .peec-action-link { display: inline-block; margin-top: 18px; font-size: 12px; color: var(--ink-soft); text-decoration: none; border-bottom: 1px dashed var(--rule-strong); padding-bottom: 2px; word-break: break-word; }
  .peec-action-link:hover { color: var(--drift); border-bottom-color: var(--drift); }

  /* Limitations grid */
  .limit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; margin-top: 40px; }
  @media (max-width: 900px) { .limit-grid { grid-template-columns: 1fr; gap: 20px; } }
  .limit-card { padding: 32px 30px 28px; background: var(--bg-alt); border-left: 3px solid var(--warn); }
  .limit-kicker { font-family: var(--sans); font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--warn); }
  .limit-title { font-family: var(--serif); font-size: 22px; font-weight: 600; line-height: 1.3; margin: 8px 0 14px; color: var(--ink); }
  .limit-body { color: var(--ink-soft); font-size: 15px; line-height: 1.6; }
  .limit-body code { background: var(--bg); padding: 2px 6px; border-radius: 2px; color: var(--ink); font-size: 0.9em; }

  /* Weekly narrative card on Overview */
  .narrative-section { padding: 64px 0; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
  .narrative-card { margin-top: 36px; padding: 36px 44px 28px; background: var(--bg-alt); border-left: 3px solid var(--drift); }
  @media (max-width: 720px) { .narrative-card { padding: 28px 22px 22px; } }
  .narrative-body { font-family: var(--serif); color: var(--ink); }
  .narrative-body .narr-h1 { font-family: var(--serif); font-size: 26px; font-weight: 700; line-height: 1.25; margin: 0 0 18px; color: var(--ink); }
  .narrative-body .narr-h2 { font-family: var(--sans); font-size: 12px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--drift); margin: 24px 0 8px; }
  .narrative-body .narr-h3 { font-family: var(--serif); font-size: 16px; font-weight: 600; margin: 16px 0 6px; color: var(--ink); }
  .narrative-body p { font-size: 16px; line-height: 1.6; color: var(--ink-soft); margin: 0 0 12px; }
  .narrative-body .narr-list { margin: 6px 0 14px; padding-left: 18px; }
  .narrative-body .narr-list li { font-size: 15px; line-height: 1.55; color: var(--ink-soft); margin-bottom: 4px; }
  .narrative-body code { font-family: var(--mono); font-size: 0.86em; background: var(--bg); padding: 2px 5px; border: 1px solid var(--rule); }
  .narrative-body .quoted { color: var(--ink); font-style: italic; }
  .narrative-body .narr-rule { border: none; border-top: 1px solid var(--rule); margin: 16px 0; }
  .narrative-body em { font-style: italic; color: var(--ink); }
  .narrative-footer { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; margin-top: 18px; padding-top: 14px; border-top: 1px solid var(--rule); flex-wrap: wrap; }
  .narrative-source { font-size: 11px; color: var(--ink-mute); letter-spacing: 0.04em; }

  /* Rules-as-markdown section */
  .rules-section { padding-top: 64px; padding-bottom: 64px; border-top: 1px solid var(--rule); }
  .rules-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; margin-top: 36px; }
  @media (max-width: 900px) { .rules-grid { grid-template-columns: 1fr; gap: 16px; } }
  .rule-card { padding: 22px 26px 22px; background: var(--bg-alt); border-left: 3px solid var(--drift); }
  .rule-card-head { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; flex-wrap: wrap; margin-bottom: 4px; }
  .rule-card-title { font-family: var(--serif); font-size: 19px; font-weight: 600; margin: 0; color: var(--ink); }
  .rule-card-file { font-size: 11px; color: var(--ink-mute); text-decoration: none; border-bottom: 1px solid transparent; }
  .rule-card-file:hover { color: var(--drift); border-bottom-color: var(--drift); }
  .rule-card-note { font-size: 13px; color: var(--ink-soft); line-height: 1.5; margin: 0 0 12px; }
  .rule-card-params { display: grid; grid-template-columns: auto 1fr; gap: 4px 16px; margin: 12px 0 0; padding-top: 12px; border-top: 1px solid var(--rule); }
  .rule-card-params dt { font-size: 11px; color: var(--ink-mute); padding-top: 2px; }
  .rule-card-params dd { font-size: 12px; color: var(--ink); margin: 0; padding-top: 2px; }

  /* Divergence-score helpers */
  .heatmap-score { cursor: help; }
  .deepdive-score-block { cursor: help; }
  .drift-score-legend { font-family: var(--mono); font-size: 11px; color: var(--ink-mute); letter-spacing: 0.02em; margin-top: 6px; }
  .drift-score-reading { margin-top: 4px; font-size: 11px; color: var(--drift); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }

  /* Mini deep-dive groups (collapsed by default) */
  .mini-groups { margin-top: 72px; border-top: 1px solid var(--rule-strong); padding-top: 48px; }
  .mini-groups-lede { max-width: 760px; margin-bottom: 28px; }
  .mini-group { border: 1px solid var(--rule); background: var(--bg); margin-bottom: 12px; }
  .mini-group summary { list-style: none; cursor: pointer; padding: 18px 24px; display: flex; align-items: center; gap: 18px; user-select: none; }
  .mini-group summary::-webkit-details-marker { display: none; }
  .mini-group summary::before { content: '›'; font-family: var(--mono); font-size: 20px; font-weight: 700; color: var(--drift); transition: transform 140ms ease; display: inline-block; flex-shrink: 0; }
  .mini-group[open] summary::before { transform: rotate(90deg); }
  .mini-group[open] summary { border-bottom: 1px solid var(--rule); }
  .mini-group-title { font-size: 18px; font-weight: 600; color: var(--ink); }
  .mini-group-count { font-size: 12px; font-weight: 700; color: var(--bg); background: var(--drift); padding: 2px 10px; border-radius: 2px; letter-spacing: 0; }
  .mini-group-note { font-family: var(--serif); font-style: italic; font-size: 14px; color: var(--ink-mute); margin-left: auto; }
  @media (max-width: 720px) { .mini-group-note { display: none; } }
  .mini-deepdive-list { padding: 8px 0; }
  .mini-deepdive { padding: 18px 24px; border-top: 1px solid var(--rule); }
  .mini-deepdive:first-child { border-top: none; }
  .mini-deepdive-head { display: flex; align-items: baseline; gap: 16px; margin-bottom: 12px; flex-wrap: wrap; }
  .mini-deepdive-score { flex-shrink: 0; font-size: 22px; font-weight: 700; color: var(--drift); letter-spacing: -0.02em; min-width: 52px; }
  .mini-deepdive-prompt { margin: 0; font-family: var(--serif); font-style: italic; font-weight: 500; font-size: 16px; line-height: 1.35; color: var(--ink); flex: 1; min-width: 280px; }
  .mini-deepdive-reading { font-family: var(--sans); font-size: 11px; color: var(--drift); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; flex-shrink: 0; }
  .mini-deepdive-reading-ownonly { color: var(--competitor); }
  .mini-deepdive-reading-full { color: var(--ink-mute); }
  .mini-deepdive-bars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px 18px; margin: 10px 0 14px; }
  @media (max-width: 720px) { .mini-deepdive-bars { grid-template-columns: 1fr; } }
  .mini-deepdive-bar { display: flex; align-items: center; gap: 8px; font-size: 12px; }
  .mini-deepdive-bar.is-silent .mini-deepdive-bar-fill { background: var(--bg-deep); }
  .mini-deepdive-bar-label { font-family: var(--sans); font-size: 11px; color: var(--ink-mute); min-width: 80px; }
  .mini-deepdive-bar-track { flex: 1; height: 6px; background: var(--bg-alt); position: relative; }
  .mini-deepdive-bar-fill { display: block; height: 100%; background: var(--drift); }
  .mini-deepdive-bar-val { font-size: 11px; font-weight: 500; min-width: 34px; text-align: right; color: var(--ink); }
  .mini-deepdive-footer { display: flex; align-items: center; gap: 16px; font-size: 12.5px; color: var(--ink-soft); flex-wrap: wrap; margin-top: 6px; }
  .mini-deepdive-topic { font-size: 11px; color: var(--ink-mute); letter-spacing: 0.02em; }
  .mini-deepdive-comp strong { color: var(--ink); font-weight: 600; }
  .mini-deepdive-brief { margin-left: auto; font-family: var(--sans); font-size: 11px; font-weight: 500; color: var(--ink); border: 1px solid var(--rule-strong); padding: 5px 10px; text-decoration: none; letter-spacing: 0.02em; transition: all 120ms ease; }
  .mini-deepdive-brief:hover { background: var(--ink); color: var(--bg); border-color: var(--ink); text-decoration: none; }
  .method-block code { background: var(--bg-alt); padding: 2px 5px; border: 1px solid var(--rule); font-size: 0.88em; white-space: nowrap; }
  .formula { font-family: var(--mono); font-size: 13px; padding: 12px 14px; background: var(--bg-alt); border-left: 2px solid var(--drift); color: var(--ink); white-space: pre-wrap; margin: 12px 0 0; overflow-x: auto; }

  /* Tab-scoped export strip – sits inside each tab section */
  .tab-export-strip { display: flex; flex-wrap: wrap; align-items: center; gap: 10px 16px; padding: 12px 0 0; margin-top: 24px; border-top: 1px dashed var(--rule-strong); font-family: var(--sans); font-size: 13px; }
  .tab-export-strip .eyebrow { margin-right: 6px; letter-spacing: 0.1em; color: var(--ink); }
  .tab-export-link { display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; background: var(--bg); border: 1px solid var(--rule); color: var(--ink-soft); text-decoration: none; transition: all 140ms ease; font-size: 12px; font-weight: 500; }
  .tab-export-link:hover { border-color: var(--drift); color: var(--drift); background: var(--bg-alt); text-decoration: none; }
  .tab-export-link .mono { font-size: 11px; font-weight: 700; color: var(--drift); padding: 2px 6px; background: var(--bg-alt); }
  .tab-export-link:hover .mono { background: var(--drift); color: var(--bg); }

  .stanza-brief-link { font-family: var(--sans); font-size: 11px; font-weight: 600; color: var(--drift); text-decoration: none; letter-spacing: 0.05em; }
  .stanza-brief-link:hover { color: var(--ink); text-decoration: underline; }

  /* Brief group accordion (Export Kit tab) */
  .brief-group { margin-bottom: 12px; border: 1px solid var(--rule); background: var(--bg-alt); }
  .brief-group summary { list-style: none; cursor: pointer; padding: 16px 22px; display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap; }
  .brief-group summary::-webkit-details-marker { display: none; }
  .brief-group summary::before { content: '›'; font-family: var(--mono); font-weight: 700; font-size: 18px; color: var(--drift); transition: transform 120ms ease; }
  .brief-group[open] summary::before { transform: rotate(90deg); }
  .brief-group-kind { font-family: var(--sans); font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--drift); padding: 3px 10px; background: var(--drift-soft); }
  .brief-group-title { font-family: var(--serif); font-weight: 700; font-size: 18px; color: var(--ink); flex: 1; }
  .brief-group-count { font-size: 12px; color: var(--ink-mute); }
  .brief-group[open] summary { border-bottom: 1px solid var(--rule); }
  .brief-group .export-brief-list { margin: 0; padding: 0 22px 16px; }
  .brief-group .export-brief-list li a { font-family: var(--serif); font-size: 14px; }

  /* Export kit */
  .exports-section { padding: 96px 0; background: var(--bg); }
  .export-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  @media (max-width: 900px) { .export-grid { grid-template-columns: 1fr; gap: 16px; } }
  .export-card { display: flex; flex-direction: column; gap: 10px; padding: 24px 26px; background: var(--bg-alt); border: 1px solid var(--rule); border-left: 3px solid var(--drift); text-decoration: none; color: var(--ink); transition: border-color 120ms ease, background 120ms ease; min-height: 180px; }
  .export-card:hover { background: var(--bg-deep); border-left-color: var(--ink); text-decoration: none; }
  .export-card-kind { font-family: var(--sans); font-size: 10px; font-weight: 600; color: var(--drift); letter-spacing: 0.14em; text-transform: uppercase; }
  .export-card-title { font-family: var(--serif); font-weight: 700; font-size: 22px; color: var(--ink); line-height: 1.2; }
  .export-card-dek { font-family: var(--sans); font-size: 14px; line-height: 1.5; color: var(--ink-soft); flex: 1; }
  .export-card-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 10px; border-top: 1px solid var(--rule); font-family: var(--sans); font-size: 12px; color: var(--ink-mute); }
  .export-card-arrow { font-family: var(--mono); font-size: 16px; font-weight: 700; color: var(--drift); }
  .export-card-group { grid-column: span 1; min-height: auto; cursor: default; }
  @media (max-width: 900px) { .export-card-group { grid-column: 1 / -1; } }
  .export-card-group:hover { background: var(--bg-alt); border-left-color: var(--drift); }
  .export-brief-list { list-style: none; padding: 0; margin: 16px 0 0; display: flex; flex-direction: column; border-top: 1px solid var(--rule); }
  .export-brief-list li { display: flex; align-items: stretch; border-bottom: 1px solid var(--rule); transition: background 120ms ease; }
  .export-brief-list li:last-child { border-bottom: none; }
  .export-brief-list li:hover { background: var(--bg-deep); }
  .export-brief-list li a.brief-list-main { flex: 1; display: flex; align-items: baseline; gap: 24px; padding: 14px 16px 14px 4px; font-family: var(--serif); font-size: 14px; line-height: 1.45; color: var(--ink); text-decoration: none; min-width: 0; }
  .export-brief-list li a.brief-list-main:hover { color: var(--drift); text-decoration: none; }
  .export-brief-list li a.brief-list-main .brief-badge { color: var(--drift); font-weight: 700; min-width: 54px; flex-shrink: 0; font-size: 13px; letter-spacing: 0.02em; }
  .export-brief-list li a.brief-list-main .brief-text { flex: 1; min-width: 0; }
  .export-brief-list li a.brief-list-main .brief-arrow { margin-left: auto; font-weight: 700; color: var(--ink-mute); font-size: 12px; letter-spacing: 0.08em; flex-shrink: 0; transition: color 120ms ease; }
  .export-brief-list li a.brief-list-main:hover .brief-arrow { color: var(--drift); }
  .export-brief-list li a.brief-list-md-btn { display: flex; align-items: center; padding: 0 16px; font-size: 11px; font-weight: 700; letter-spacing: 0.08em; color: var(--ink-mute); text-decoration: none; border-left: 1px solid var(--rule); transition: color 120ms ease, background 120ms ease; flex-shrink: 0; }
  .export-brief-list li a.brief-list-md-btn:hover { color: var(--drift); background: var(--bg-alt); text-decoration: none; }

  /* Deep-dive meta strip (topic, volume, tags) */
  .deepdive-meta { display: flex; flex-wrap: wrap; gap: 28px; margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--rule); }
  .deepdive-meta-item { display: flex; flex-direction: column; gap: 2px; font-family: var(--sans); font-size: 13px; color: var(--ink); }
  .deepdive-meta-item .eyebrow { font-size: 10px; letter-spacing: 0.12em; color: var(--ink-mute); }

  /* Search-intent block per deep-dive */
  .search-intent-block { margin-top: 32px; padding: 24px 28px; background: var(--bg-alt); border-left: 3px solid var(--own); }
  .search-intent-head { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
  .search-intent-note { font-family: var(--sans); font-size: 13px; color: var(--ink-mute); line-height: 1.5; }
  .search-intent-group { margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--rule); }
  .search-intent-group:first-of-type { border-top: none; padding-top: 0; margin-top: 0; }
  .search-intent-label { font-family: var(--sans); font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--own); margin-bottom: 10px; }
  .search-intent-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; }
  .search-intent-list li { font-size: 12px; color: var(--ink-soft); padding: 4px 0; border-bottom: 1px solid var(--rule); line-height: 1.45; }
  .search-intent-list li:last-child { border-bottom: none; }
  .search-intent-products { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
  .search-intent-products li { display: flex; flex-direction: column; gap: 4px; padding: 8px 0; border-bottom: 1px solid var(--rule); }
  .search-intent-products li:last-child { border-bottom: none; }
  .search-intent-q { font-size: 11px; color: var(--own); }
  .search-intent-prod { font-family: var(--serif); font-size: 14px; color: var(--ink); line-height: 1.5; }

  /* Gap URL excerpt */
  .gap-url-excerpt { margin-top: 12px; padding: 12px 16px; background: var(--bg); border-left: 2px solid var(--competitor); }
  .gap-url-excerpt-label { font-family: var(--sans); font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--competitor); margin-bottom: 6px; }
  .gap-url-excerpt-body { font-family: var(--serif); font-size: 14px; line-height: 1.55; color: var(--ink-soft); font-style: italic; margin: 0; }
  .gap-url-excerpt-angle { font-family: var(--sans); font-size: 13px; line-height: 1.55; color: var(--ink); margin: 8px 0 0; }
  .gap-url-excerpt-angle strong { color: var(--drift); }

  /* Gap URLs block per deep-dive */
  .gap-urls-block { margin-top: 32px; padding: 24px 28px; background: var(--bg-alt); border-left: 3px solid var(--competitor); }
  .gap-urls-head { display: flex; justify-content: space-between; align-items: baseline; gap: 24px; margin-bottom: 8px; }
  .gap-urls-count { font-size: 12px; color: var(--ink-mute); }
  .gap-urls-caption { margin-bottom: 16px; max-width: 720px; }
  .gap-urls-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 14px; }
  .gap-url-item { padding: 14px 0; border-top: 1px solid var(--rule); }
  .gap-url-item:first-child { border-top: none; padding-top: 0; }
  .gap-url-title { font-family: var(--serif); font-weight: 600; font-size: 16px; color: var(--ink); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 120ms ease; display: block; line-height: 1.4; }
  .gap-url-title:hover { color: var(--drift); border-bottom-color: var(--drift); text-decoration: none; }
  .gap-url-meta { font-size: 11px; color: var(--ink-mute); margin-top: 4px; }
  .gap-url-class { text-transform: capitalize; color: var(--competitor); font-weight: 700; }
  .gap-url-href { font-size: 11px; color: var(--ink-mute); margin-top: 4px; word-break: break-all; line-height: 1.5; }

  /* Dataset-ship block on exports tab */
  .dataset-ship { margin-top: 56px; padding: 40px; background: var(--bg-alt); border-left: 3px solid var(--drift); }
  .dataset-ship-head { font-family: var(--serif); font-size: 26px; margin-top: 8px; font-weight: 600; }
  .dataset-ship-caption { margin-top: 12px; max-width: 720px; }
  .dataset-ship-grid { display: flex; flex-direction: column; gap: 0; margin-top: 32px; border-top: 1px solid var(--rule-strong); }
  .dataset-ship-row { display: flex; align-items: center; gap: 32px; padding: 20px 0; border-bottom: 1px solid var(--rule); }
