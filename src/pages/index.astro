  <script id="drift-slack-payload" type="application/json" set:html={JSON.stringify({
    text:
      `*Drift Radar · ${own_brand} · ${date_range.start} → ${date_range.end}*\n` +
      `• ${summary.own_silence_percent}% own-brand silence (${summary.own_silence_count}/${summary.total_prompts} prompts)\n` +
      `• ${summary.own_only_silence_count} own-only silence · ${summary.full_silence_count} full silence\n` +
      `• ${summary.high_divergence_count} drifting prompts (divergence ≥ 0.30)\n` +
      `• Average own visibility ${(summary.avg_own_visibility*100).toFixed(1)}%\n\n` +
      `Report: https://drift-radar.pages.dev`
  })}></script>

  <script is:inline>
    (function() {
      // Tab routing – URL-hash driven
      var TABS = ['overview', 'heatmap', 'deepdives', 'exports', 'stack', 'underhood'];

      function activateTab(tabName, scrollToId) {
        var valid = TABS.indexOf(tabName) >= 0 ? tabName : 'overview';
        var body = document.body;
        body.className = body.className.replace(/\btab-\w+\b/g, '').trim();
        body.classList.add('tab-' + valid);
        document.querySelectorAll('.tab-nav-btn').forEach(function(b) {
          b.classList.toggle('is-active', b.getAttribute('data-tab') === valid);
        });
        if (scrollToId) {
          setTimeout(function() {
            var el = document.getElementById(scrollToId);
            if (el) el.scrollIntoView({ behavior: 'auto', block: 'start' });
          }, 30);
        } else {
          window.scrollTo(0, 0);
        }
      }

      function resolveFromHash() {
        var h = (window.location.hash || '').replace('#', '');
        if (h.indexOf('deepdive-') === 0) {
          activateTab('deepdives', h);
        } else if (TABS.indexOf(h) >= 0) {
          activateTab(h);
        } else {
          activateTab('overview');
        }
      }

      resolveFromHash();
      window.addEventListener('hashchange', resolveFromHash);

      document.addEventListener('click', function(ev) {
        var btn = ev.target && ev.target.closest && ev.target.closest('.tab-nav-btn');
        if (!btn) return;
        ev.preventDefault();
        var tab = btn.getAttribute('data-tab');
        if (tab) window.location.hash = '#' + tab;
      });

      // Mobile deep-dive expand: click the Tap-to-expand button or expand via hash
      document.addEventListener('click', function(ev) {
        var toggle = ev.target && ev.target.closest && ev.target.closest('[data-dd-toggle]');
        if (!toggle) return;
        var article = toggle.closest('.deepdive');
        if (!article) return;
        var expanded = article.classList.toggle('is-expanded');
        toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        if (expanded) {
          setTimeout(function () { article.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 40);
        }
      });
      function expandDeepdiveFromHash() {
        var h = (window.location.hash || '').replace('#', '');
        if (h.indexOf('deepdive-') !== 0) return;
        var target = document.getElementById(h);
        if (target && target.classList.contains('deepdive')) {
          target.classList.add('is-expanded');
          var toggle = target.querySelector('[data-dd-toggle]');
          if (toggle) toggle.setAttribute('aria-expanded', 'true');
        }
      }
      expandDeepdiveFromHash();
      window.addEventListener('hashchange', expandDeepdiveFromHash);

      var toast = document.getElementById('share-toast');
      var toastTimer = null;
      var isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform || navigator.userAgent || '');
      var pasteShortcut = isMac ? '⌘V' : 'Ctrl+V';
      function destFromUrl(url) {
        if (!url) return null;
        if (/notion\.so/.test(url)) return 'Notion';
        if (/docs\.google\.com\/spreadsheets/.test(url)) return 'Google Sheets';
        if (/docs\.google\.com\/document/.test(url)) return 'Google Docs';
        return null;
      }
      function showToast(msg, pasteHintDest) {
        if (!toast) return;
        toast.classList.remove('is-paste-hint');
        if (pasteHintDest) {
          toast.classList.add('is-paste-hint');
          toast.innerHTML = '';
          var title = document.createElement('div');
          title.className = 'toast-title';
          title.textContent = msg;
          var sub = document.createElement('div');
          sub.className = 'toast-sub';
          sub.textContent = 'Press ' + pasteShortcut + ' in the new ' + pasteHintDest + ' tab';
          toast.appendChild(title);
          toast.appendChild(sub);
        } else {
          toast.textContent = msg;
        }
        toast.classList.add('is-visible');
        clearTimeout(toastTimer);
        toastTimer = setTimeout(function() { toast.classList.remove('is-visible'); }, pasteHintDest ? 6000 : 1800);
      }
      // Heatmap filter toggle – status buttons + tag buttons combine
      function applyHeatmapFilters() {
        var statusBtn = document.querySelector('.filter-btn:not(.filter-tag-btn).is-active');
        var tagBtn = document.querySelector('.filter-tag-btn.is-active');
        var statusFilter = statusBtn ? statusBtn.getAttribute('data-filter') : 'all';
        var tagFilter = tagBtn ? tagBtn.getAttribute('data-tag') : 'all';
        document.querySelectorAll('.heatmap-row').forEach(function(row) {
          var hideStatus = false;
          if (statusFilter === 'drifting') hideStatus = !row.classList.contains('is-drifting');
          else if (statusFilter === 'own-only') hideStatus = !row.classList.contains('has-competitors');
          else if (statusFilter === 'full-silence') hideStatus = !row.classList.contains('is-full-silence');
          else if (statusFilter === 'has-deepdive') hideStatus = !row.classList.contains('has-deepdive');
          var hideTag = false;
          if (tagFilter && tagFilter !== 'all') {
            var tags = (row.getAttribute('data-tags') || '').split(',');
            hideTag = tags.indexOf(tagFilter) < 0;
          }
          row.style.display = (hideStatus || hideTag) ? 'none' : '';
        });
      }
      document.addEventListener('click', function(ev) {
        var fbtn = ev.target && ev.target.closest && ev.target.closest('.filter-btn');
        if (!fbtn) return;
        var isTag = fbtn.classList.contains('filter-tag-btn');
        var siblingSelector = isTag ? '.filter-tag-btn' : '.filter-btn:not(.filter-tag-btn)';
        document.querySelectorAll(siblingSelector).forEach(function(b) {
          b.classList.toggle('is-active', b === fbtn);
        });
        applyHeatmapFilters();
      });

      // Heatmap row click → anchor jump to Deep-Dive
      document.addEventListener('click', function(ev) {
        if (ev.target.closest('a')) return;            // inner anchor wins
        if (ev.target.closest('[data-clipboard-text]')) return; // copy button wins
        var row = ev.target && ev.target.closest && ev.target.closest('.heatmap-row.has-deepdive[data-deepdive-href]');
        if (!row) return;
        var href = row.getAttribute('data-deepdive-href');
        if (href) window.location.hash = href;
      });

      // Slack webhook: POST client-side to a user-supplied incoming-webhook URL.
      var slackBtn = document.getElementById('slack-post-btn');
      var slackInput = document.getElementById('slack-webhook');
      var slackPayloadEl = document.getElementById('drift-slack-payload');
      var slackPayload = slackPayloadEl ? JSON.parse(slackPayloadEl.textContent || '{}') : { text: 'Drift Radar report' };
      if (slackBtn && slackInput) {
        slackBtn.addEventListener('click', function() {
          var url = slackInput.value.trim();
          if (!url || !/^https:\/\/hooks\.slack\.com\//.test(url)) {
            showToast('Paste a valid https://hooks.slack.com/... URL');
            return;
          }
          slackBtn.disabled = true;
          var original = slackBtn.textContent;
          slackBtn.textContent = 'Posting…';
          fetch(url, {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify(slackPayload),
          }).then(function(r) {
            if (r.ok) { showToast('Posted to Slack ✓'); slackInput.value = ''; }
            else { showToast('Slack rejected the post (' + r.status + ')'); }
          }).catch(function() {
            showToast('Network error – check the webhook URL');
          }).finally(function() {
            slackBtn.disabled = false;
            slackBtn.textContent = original;
          });
        });
      }

      document.addEventListener('click', function(ev) {
        var btn = ev.target && ev.target.closest && ev.target.closest('[data-clipboard-text]');
        if (!btn) return;
        ev.preventDefault();
        var text = btn.getAttribute('data-clipboard-text') || '';
        var msg = btn.getAttribute('data-toast') || 'Copied';
        var openUrl = btn.getAttribute('data-open-url');
        var pasteDest = destFromUrl(openUrl);
        var finish = function(ok) {
          if (ok) {
            btn.classList.add('is-copied');
            var originalText = btn.textContent;
            btn.textContent = pasteDest ? ('✓ Copied – now press ' + pasteShortcut) : ('✓ ' + msg);
            setTimeout(function() {
              btn.classList.remove('is-copied');
              btn.textContent = originalText;
            }, pasteDest ? 4000 : 1600);
            showToast(msg, pasteDest);
            if (openUrl) {
              // Brief delay so the user sees the toast before the new tab grabs focus.
              setTimeout(function() { window.open(openUrl, '_blank', 'noopener'); }, 260);
            }
          } else {
            showToast('Copy failed – please copy manually');
          }
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(function() { finish(true); }, function() { finish(false); });
        } else {
          // Fallback: textarea + execCommand
          var ta = document.createElement('textarea');
          ta.value = text; ta.setAttribute('readonly', '');
          ta.style.position = 'absolute'; ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          var ok = false;
          try { ok = document.execCommand('copy'); } catch (_) {}
          document.body.removeChild(ta);
          finish(ok);
        }
      });

      // --- Scan-strip trigger button · jury-accessible workflow_dispatch via CF Worker ---
      (function() {
        var btn = document.getElementById('scan-trigger-btn');
        if (!btn) return;
        var originalText = btn.textContent;
        var url = btn.getAttribute('data-trigger-url');
        btn.addEventListener('click', function() {
          if (btn.disabled) return;
          btn.disabled = true;
          btn.classList.remove('is-ok', 'is-err');
          btn.textContent = 'Dispatching…';
          fetch(url, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: '{}',
          })
            .then(function(r) { return r.json().then(function(j) { return { status: r.status, body: j }; }); })
            .then(function(res) {
              if (res.status === 200 && res.body && res.body.ok) {
                btn.classList.add('is-ok');
                btn.textContent = 'Dispatched ✓ – see history ↗';
                showToast('Workflow dispatched. Run appears in the history tab in 5–10 s.');
                // Open the runs page so the user can watch the fresh run show up.
                if (res.body.runs_url) {
                  setTimeout(function() { window.open(res.body.runs_url, '_blank', 'noopener'); }, 400);
                }
              } else if (res.status === 429) {
                btn.classList.add('is-err');
                btn.textContent = 'Wait ' + (res.body.retry_after_seconds || 60) + 's · try again';
                showToast('Rate limited: wait ' + (res.body.retry_after_seconds || 60) + 's, then retry.');
              } else {
                btn.classList.add('is-err');
                btn.textContent = 'Dispatch failed · retry';
                showToast((res.body && res.body.error) ? res.body.error : 'Dispatch failed – see history for status.');
              }
            })
            .catch(function(e) {
              btn.classList.add('is-err');
              btn.textContent = 'Network error · retry';
              showToast('Network error reaching the trigger worker.');
            })
            .finally(function() {
              setTimeout(function() {
                btn.disabled = false;
                btn.classList.remove('is-ok', 'is-err');
                btn.textContent = originalText;
              }, 6000);
            });
        });
      })();

      // --- Strip plot · hover tooltip + click scroll to deep dive ---
      (function() {
        var svg = document.querySelector('.strip-svg');
        var tooltip = document.getElementById('strip-tooltip');
        if (!svg || !tooltip) return;
        var promptEl = tooltip.querySelector('.strip-tooltip-prompt');
        var metaEl = tooltip.querySelector('.strip-tooltip-meta');
        var linkEl = tooltip.querySelector('.strip-tooltip-link');
        var activeBar = null;
        var STRIP_VIEW_W = 1100;

        var silenceLabel = { 'active': 'active', 'own_only': 'own-only silence', 'full': 'full silence' };
        function reading(d) {
          if (d >= 0.80) return 'three non-overlapping answers';
          if (d >= 0.50) return 'two versions compete';
          if (d >= 0.30) return 'narrative is drifting';
          return 'engines aligned';
        }

        function show(bar) {
          var pid = bar.getAttribute('data-prompt-id');
          var text = bar.getAttribute('data-prompt-text') || '';
          var div = parseFloat(bar.getAttribute('data-div')) || 0;
          var silence = bar.getAttribute('data-silence') || 'active';
          var comp = bar.getAttribute('data-top-comp') || '';
          var hasDD = bar.getAttribute('data-has-dd') === '1';

          promptEl.textContent = '»' + text + '«';
          var parts = ['divergence ' + div.toFixed(2), reading(div), silenceLabel[silence] || silence];
          if (comp) parts.push('top competitor: ' + comp);
          metaEl.textContent = parts.join(' · ');
          if (hasDD) { linkEl.hidden = false; linkEl.setAttribute('href', '#deepdive-' + pid); }
          else { linkEl.hidden = true; }

          var wrap = tooltip.parentElement;
          var wrapRect = wrap.getBoundingClientRect();
          var svgRect = svg.getBoundingClientRect();
          var scaleX = svgRect.width / STRIP_VIEW_W;
          var scaleY = svgRect.height / 320;
          var bx = parseFloat(bar.getAttribute('x'));
          var by = parseFloat(bar.getAttribute('y'));
          var bw = parseFloat(bar.getAttribute('width'));
          var left = (svgRect.left - wrapRect.left) + (bx + bw / 2) * scaleX;
          var top = (svgRect.top - wrapRect.top) + by * scaleY;
          // Clamp inside the wrap so the tooltip never escapes left/right edge
          var minLeft = 100;
          var maxLeft = wrapRect.width - 100;
          if (left < minLeft) left = minLeft;
          if (left > maxLeft) left = maxLeft;
          tooltip.style.left = left + 'px';
          tooltip.style.top = top + 'px';
          tooltip.classList.add('is-visible');
          tooltip.setAttribute('aria-hidden', 'false');

          if (activeBar && activeBar !== bar) activeBar.classList.remove('is-active');
          bar.classList.add('is-active');
          activeBar = bar;
        }
        function hide() {
          tooltip.classList.remove('is-visible');
          tooltip.setAttribute('aria-hidden', 'true');
          if (activeBar) { activeBar.classList.remove('is-active'); activeBar = null; }
        }

        svg.addEventListener('mouseover', function(e) {
          var t = e.target;
          if (t && t.classList && t.classList.contains('strip-bar')) show(t);
        });
        svg.addEventListener('mouseout', function(e) {
          var t = e.target;
          if (t && t.classList && t.classList.contains('strip-bar')) {
            var related = e.relatedTarget;
            if (related && tooltip.contains(related)) return;
            hide();
          }
        });
        tooltip.addEventListener('mouseleave', hide);

        svg.addEventListener('click', function(e) {
          var t = e.target;
          if (!t || !t.classList || !t.classList.contains('strip-bar')) return;
          var hasDD = t.getAttribute('data-has-dd') === '1';
          var pid = t.getAttribute('data-prompt-id');
          if (hasDD) { window.location.hash = 'deepdive-' + pid; }
          else { show(t); }
        });

        svg.addEventListener('touchstart', function(e) {
