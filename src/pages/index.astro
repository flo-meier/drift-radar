                const xs = pts.map((_: number, i: number) => pad + (i * (w - 2*pad)) / Math.max(1, pts.length - 1));
                const ys = pts.map((v: number) => h - pad - (v / trendMax) * (h - 2*pad));
                const d = xs.map((x: number, i: number) => `${i === 0 ? 'M' : 'L'} ${x.toFixed(1)} ${ys[i].toFixed(1)}`).join(' ');
                const last = pts[pts.length - 1];
                return (
                  <div class="trend-row">
