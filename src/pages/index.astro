---
import Base from '../layouts/Base.astro';
import KeyVisual from '../components/KeyVisual.astro';
import data from '../data/drift_radar.json';
import peecActions from '../data/peec_actions.json';
import trendByDate from '../data/trend_by_date.json';
import lastScan from '../data/last_scan.json';
import crossRefs from '../data/cross_refs.json';
import narrativeLatest from '../data/narrative_latest.md?raw';

const { project, own_brand, date_range, active_models, competitors, summary, prompts, source_overview, source_classifications } = data as any;
const peecTopActions = (peecActions as any).top_actions || [];

// Parse the weekly narrative markdown for the Overview teaser card.
// Tiny markdown subset: H1, H2, H3, paragraphs, bullet lists, italics, strong.
const narrativeText = (narrativeLatest || '') as string;
function escapeHtml(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}
function inlineMd(s: string): string {
  return escapeHtml(s)
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    .replace(/(?<![*])\*([^*]+)\*(?![*])/g, '<em>$1</em>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/»([^«]+)«/g, '<span class="quoted">»$1«</span>');
}
function renderNarrative(md: string): string {
  const lines = md.split('\n');
  const out: string[] = [];
  let inList = false;
  let inPara: string[] = [];
  const flushPara = () => { if (inPara.length) { out.push(`<p>${inlineMd(inPara.join(' '))}</p>`); inPara = []; } };
  const closeList = () => { if (inList) { out.push('</ul>'); inList = false; } };
  for (const raw of lines) {
    const line = raw.replace(/\s+$/, '');
    if (!line.trim()) { flushPara(); closeList(); continue; }
    if (line.startsWith('# ')) { flushPara(); closeList(); out.push(`<h3 class="narr-h1">${inlineMd(line.slice(2))}</h3>`); continue; }
    if (line.startsWith('## ')) { flushPara(); closeList(); out.push(`<h4 class="narr-h2">${inlineMd(line.slice(3))}</h4>`); continue; }
    if (line.startsWith('### ')) { flushPara(); closeList(); out.push(`<h5 class="narr-h3">${inlineMd(line.slice(4))}</h5>`); continue; }
    if (line.startsWith('- ')) { flushPara(); if (!inList) { out.push('<ul class="narr-list">'); inList = true; } out.push(`<li>${inlineMd(line.slice(2))}</li>`); continue; }
    if (line.startsWith('---')) { flushPara(); closeList(); out.push('<hr class="narr-rule" />'); continue; }
    inPara.push(line);
  }
  flushPara(); closeList();
  return out.join('\n');
}
const narrativeHtml = renderNarrative(narrativeText);
const narrativeIsBaseline = narrativeText.includes('First run') || narrativeText.includes('baseline');

// Trend data: build per-date × per-engine visibility map
const trendRows = (trendByDate as any).rows || [];
const trendDates: string[] = Array.from(new Set(trendRows.map((r: any) => r.date))).sort() as string[];
const trendByEngine: Record<string, Record<string, number>> = {};
for (const r of trendRows) {
  if (!trendByEngine[r.model_id]) trendByEngine[r.model_id] = {};
  trendByEngine[r.model_id][r.date] = r.visibility;
}
const trendMax = Math.max(0.01, ...trendRows.map((r: any) => r.visibility || 0));

const SOURCE_CLASS_ORDER = ['OWN', 'COMPETITOR', 'EDITORIAL', 'UGC', 'REFERENCE', 'INSTITUTIONAL', 'CORPORATE', 'OTHER'];
const SOURCE_CLASS_LABELS: Record<string, string> = {
  OWN: 'You', COMPETITOR: 'Competitor', EDITORIAL: 'Editorial',
  UGC: 'UGC', REFERENCE: 'Reference', INSTITUTIONAL: 'Institutional',
  CORPORATE: 'Corporate', OTHER: 'Other',
};

const modelOrder = active_models.map((m: any) => m.id);

function formatScanDate(iso: string): string {
  const d = new Date(iso);
  const day = String(d.getUTCDate()).padStart(2, '0');
  const month = String(d.getUTCMonth() + 1).padStart(2, '0');
  const hh = String(d.getUTCHours()).padStart(2, '0');
  const mm = String(d.getUTCMinutes()).padStart(2, '0');
  return `${d.getUTCFullYear()}-${month}-${day} ${hh}:${mm} UTC`;
}
const scanLastLabel = formatScanDate((lastScan as any).timestamp);
const scanNextLabel = formatScanDate((lastScan as any).next_scheduled);
const scanSource = (lastScan as any).source;
const scanWorkflowUrl = (lastScan as any).workflow_url;
const scanApiKeyPresent = (lastScan as any).peec_api_key_present;

const gscPayload = (crossRefs as any).gsc;
const gscTop = (gscPayload && gscPayload.top_priority) || [];
const gscSource = gscPayload?.source || 'demo';
const gscNote = gscPayload?.note || '';

const ga4Payload = (crossRefs as any).ga4;
const ga4Top = (ga4Payload && ga4Payload.top_risk) || [];
const ga4Source = ga4Payload?.source || 'demo';
const ga4Note = ga4Payload?.note || '';
const ga4PropertyName = ga4Payload?.property_name || '';
const ga4Totals = ga4Payload?.totals || {};
const ga4MaxRisk = Math.max(1, ...ga4Top.map((r: any) => r.revenue_at_risk || 0));

const ahrefsPayload = (crossRefs as any).ahrefs;
const ahrefsTop = (ahrefsPayload && ahrefsPayload.top_opportunity) || [];
const ahrefsSource = ahrefsPayload?.source || 'demo';
const ahrefsNote = ahrefsPayload?.note || '';
const ahrefsCoverage = ahrefsPayload?.coverage || {};
const ahrefsMaxOpp = Math.max(0.01, ...ahrefsTop.map((r: any) => r.opportunity_score || 0));

function shortUrl(url: string, max = 52): string {
  if (!url) return '';
  let trimmed = url.replace(/^https?:\/\//, '').replace(/^www\./, '');
  if (trimmed.length > max) trimmed = trimmed.slice(0, max - 1) + '…';
  return trimmed;
}

function euro(n: number): string {
  return '€' + Math.round(n).toLocaleString('en-US');
}

const sortedPrompts = [...prompts].sort((a: any, b: any) => b.divergence_score - a.divergence_score);
const heatmapRows = sortedPrompts.slice(0, 20);
const deepDives = sortedPrompts.filter((p: any) => p.chat_sample);
const deepDivePromptIds = new Set(deepDives.map((p: any) => p.prompt_id));

// Secondary deep-dive groups: collapsed by default, render one mini-card each.
const remainingDrifting = sortedPrompts.filter(
  (p: any) => p.divergence_score >= 0.30 && !deepDivePromptIds.has(p.prompt_id)
);
const remainingOwnOnly = sortedPrompts.filter(
  (p: any) =>
    p.silence_type === 'own_only' &&
    !deepDivePromptIds.has(p.prompt_id) &&
    p.divergence_score < 0.30,
);
const remainingFull = sortedPrompts.filter(
  (p: any) =>
    p.silence_type === 'full' &&
    !deepDivePromptIds.has(p.prompt_id) &&
    p.divergence_score < 0.30,
);

function divergenceReading(score: number): string {
  if (score >= 0.80) return 'three non-overlapping answers';
  if (score >= 0.50) return 'two versions compete';
  if (score >= 0.30) return 'narrative is drifting';
  return 'engines aligned';
}

// Strip-plot — every prompt as one vertical bar, sorted by content-priority
// score desc. Height encodes priority (drifting score for divergence prompts,
// fixed "risk band" levels for silent prompts so the silent set is visible too).
// Colour encodes failure mode. Static, FT-/Bloomberg-style.
const STRIP_VIEW_W = 1100;
const STRIP_VIEW_H = 320;
const STRIP_PAD_LEFT = 56;
const STRIP_PAD_RIGHT = 24;
const STRIP_PAD_TOP = 16;
const STRIP_PAD_BOTTOM = 56;
const STRIP_PLOT_W = STRIP_VIEW_W - STRIP_PAD_LEFT - STRIP_PAD_RIGHT;
const STRIP_PLOT_H = STRIP_VIEW_H - STRIP_PAD_TOP - STRIP_PAD_BOTTOM;
// Risk-band heights for silent prompts so they show up on the chart.
const PRIORITY_OWN_ONLY = 0.55;
const PRIORITY_FULL = 0.35;
function priorityScore(p: any): number {
  const div = Number(p.divergence_score || 0);
  if (p.silence_type === 'own_only') return Math.max(div, PRIORITY_OWN_ONLY);
  if (p.silence_type === 'full') return Math.max(div, PRIORITY_FULL);
  return div;
}
const stripSorted = [...prompts].sort((a: any, b: any) => priorityScore(b) - priorityScore(a));
const STRIP_STRIDE = STRIP_PLOT_W / Math.max(1, stripSorted.length);
const STRIP_BAR_W = Math.max(8, STRIP_STRIDE - 4);
const stripBars = stripSorted.map((p: any, i: number) => {
  const div = Number(p.divergence_score || 0);
  const prio = Math.max(0, Math.min(1, priorityScore(p)));
  const x = +(STRIP_PAD_LEFT + i * STRIP_STRIDE + (STRIP_STRIDE - STRIP_BAR_W) / 2).toFixed(1);
  const barH = +(prio * STRIP_PLOT_H).toFixed(1);
  const y = +(STRIP_PAD_TOP + STRIP_PLOT_H - barH).toFixed(1);
  let cls = 'strip-bar-active';
  if (p.silence_type === 'full') cls = 'strip-bar-full';
  else if (p.silence_type === 'own_only') cls = 'strip-bar-ownonly';
  else if (div >= 0.30) cls = 'strip-bar-drift';
  return {
    id: p.prompt_id,
    x,
    y,
    w: STRIP_BAR_W,
    h: Math.max(1.5, barH),
    cls,
    text: p.prompt_text || '',
    div: Number(div.toFixed(2)),
    prio: Number(prio.toFixed(2)),
    silence: p.silence_type || 'active',
    topComp: p.top_competitors?.[0]?.brand_name || '',
    hasDD: !!p.chat_sample,
  };
});
const stripCounts = {
  drift: stripBars.filter((d: any) => d.cls === 'strip-bar-drift').length,
  ownOnly: stripBars.filter((d: any) => d.cls === 'strip-bar-ownonly').length,
  full: stripBars.filter((d: any) => d.cls === 'strip-bar-full').length,
  active: stripBars.filter((d: any) => d.cls === 'strip-bar-active').length,
};
function stripY(score: number): number {
  return +(STRIP_PAD_TOP + STRIP_PLOT_H - score * STRIP_PLOT_H).toFixed(1);
}

function slugify(text: string, maxLen = 48): string {
  const s = String(text).toLowerCase().replace(/[^\w\s-]/g, '').trim().replace(/[\s_-]+/g, '-');
  return s.slice(0, maxLen).replace(/-+$/, '');
}

function briefFilename(p: any, kind?: 'own_only' | 'full_silence'): string {
  const pidRaw = String(p.prompt_id || '').replace(/^pr_/, '').split('-')[0].slice(0, 8);
  const slug = slugify(p.prompt_text || '', 44);
  const prefix = kind === 'own_only' ? 'own-only-' : kind === 'full_silence' ? 'full-silence-' : '';
  return `brief-${prefix}${pidRaw}-${slug}.pdf`;
}

function briefMdFilename(p: any, kind?: 'own_only' | 'full_silence'): string {
  return briefFilename(p, kind).replace(/\.pdf$/, '.md');
}

function volumeLabel(p: any): string {
  // Prefer Peec's bucket label (very low / low / medium / high / very high).
  if (p.volume_bucket) return p.volume_bucket;
  return '–';
}

function volumeBucketRank(label: string | null | undefined): number {
  switch ((label || '').toLowerCase()) {
    case 'very high': return 5;
    case 'high': return 4;
    case 'medium': return 3;
    case 'low': return 2;
    case 'very low': return 1;
    default: return 0;
  }
}

function datasetTsv(promptList: any[]): string {
  const cols = [
    'prompt_id', 'prompt_text', 'topic', 'volume',
    'divergence_score', 'silence_type',
    ...active_models.map((m: any) => `visibility_${m.name.toLowerCase().replace(/\s+/g, '_')}`),
    'top_competitors',
  ];
  const rows = [cols.join('\t')];
  for (const p of promptList) {
    const vals: any[] = [
      p.prompt_id, p.prompt_text, p.topic, p.volume ?? '',
      p.divergence_score, p.silence_type ?? '',
      ...active_models.map((m: any) => p.visibility_by_model?.[m.id] ?? 0),
      (p.top_competitors || []).slice(0, 5)
        .map((c: any) => `${c.brand_name} (${Math.round(c.max_visibility * 100)}%)`)
        .join(', '),
    ];
    rows.push(vals.map(v => String(v).replace(/[\t\n\r]/g, ' ')).join('\t'));
  }
  return rows.join('\n');
}

function datasetMdTable(promptList: any[], title: string): string {
  const lines: string[] = [];
  lines.push(`# ${title}`);
  lines.push('');
  lines.push(`_Drift Radar · ${own_brand} · ${date_range.start} → ${date_range.end} · ${promptList.length} prompts_`);
  lines.push('');
  lines.push(`| Divergence | Silence | Prompt | ${active_models.map((m: any) => m.name).join(' | ')} | Top competitors |`);
  lines.push(`|---|---|---|${active_models.map(() => '---').join('|')}|---|`);
  for (const p of promptList) {
    const text = p.prompt_text.replace(/\|/g, '\\|');
    const engines = active_models.map((m: any) => `${Math.round((p.visibility_by_model?.[m.id] ?? 0) * 100)}%`).join(' | ');
    const comps = (p.top_competitors || []).slice(0, 3).map((c: any) => c.brand_name).join(', ') || '–';
    lines.push(`| ${p.divergence_score.toFixed(2)} | ${p.silence_type || '–'} | »${text}« | ${engines} | ${comps} |`);
  }
  lines.push('');
  lines.push('---');
  lines.push('Source: Peec AI MCP · Drift Radar · Built for the Peec AI MCP Challenge 2026 · #BuiltWithPeec');
  return lines.join('\n');
}

const masterTsv = datasetTsv(prompts);
const driftingTsv = datasetTsv(prompts.filter((p: any) => p.divergence_score >= 0.3));
const ownOnlyTsv = datasetTsv(prompts.filter((p: any) => p.silence_type === 'own_only'));
const fullSilenceTsv = datasetTsv(prompts.filter((p: any) => p.silence_type === 'full'));
const masterMd = datasetMdTable(prompts, `Drift Radar – ${own_brand} · master dataset`);
const driftingMd = datasetMdTable(prompts.filter((p: any) => p.divergence_score >= 0.3), `Drift Radar – drifting prompts (≥ 0.30)`);
const ownOnlyMd = datasetMdTable(prompts.filter((p: any) => p.silence_type === 'own_only'), `Drift Radar – own-only silence prompts`);
const fullSilenceMd = datasetMdTable(prompts.filter((p: any) => p.silence_type === 'full'), `Drift Radar – full silence prompts`);

function buildMarkdown(p: any): string {
  const cs = p.chat_sample || {};
  const cSummary = cs.claim_summary || {};
  const typeCounts = cSummary.type_counts_by_model || {};
  const lines: string[] = [];
  lines.push(`# Drift Radar – »${p.prompt_text}«`);
  lines.push('');
  lines.push(`**Divergence:** ${p.divergence_score.toFixed(2)} · **Silence:** ${p.silence_type || 'none'} · **Topic:** ${p.topic || '-'} · **Volume:** ${p.volume_bucket || '-'} (Peec search-volume bucket)`);
  lines.push('');
  if (cs.narrative) { lines.push(`> ${cs.narrative}`); lines.push(''); }
  lines.push('## What the engines say');
  lines.push('');
  for (const m of active_models) {
    const per = (cs.by_model || {})[m.id] || {};
    const vis = p.visibility_by_model?.[m.id] ?? 0;
    lines.push(`### ${m.name} – visibility ${Math.round(vis * 100)}%`);
    if (per.note) { lines.push(`_${per.note}_`); lines.push(''); continue; }
    const brands = per.brands_mentioned || [];
    if (brands.length) {
      lines.push(`**Brands cited:** ${brands.map((b: any) => `#${b.position} ${b.name}`).join(', ')}`);
    } else {
      lines.push(`**Brands cited:** _none tracked_`);
    }
    const counts = typeCounts[m.id] || {};
    const typeStr = CLAIM_TYPES.filter((t: ClaimType) => (counts[t] || 0) > 0).map((t: ClaimType) => `${counts[t]} ${t}`).join(' · ');
    if (typeStr) lines.push(`**Claim mix:** ${typeStr}`);
    for (const c of (per.claims || []).slice(0, 5)) {
      lines.push(`- _${c.type}_ – ${c.text}`);
    }
    if (per.caveat) lines.push(`> ${per.caveat}`);
    lines.push('');
  }
  const sharedSub = cSummary.shared_substances || [];
  const sharedCrit = cSummary.shared_criteria || [];
  if (sharedSub.length || sharedCrit.length) {
    lines.push('## Stable concepts across engines');
    if (sharedSub.length) lines.push(`- Substances: ${sharedSub.join(', ')}`);
    if (sharedCrit.length) lines.push(`- Criteria: ${sharedCrit.join(', ')}`);
    lines.push('');
  }
  lines.push('---');
  lines.push(`Source: Peec AI MCP · ${date_range.start} → ${date_range.end} · Drift Radar · Built for the Peec AI MCP Challenge 2026 · #BuiltWithPeec`);
  return lines.join('\n');
}

function buildSlackText(p: any): string {
  const visMap = p.visibility_by_model || {};
  const active = active_models.filter((m: any) => (visMap[m.id] ?? 0) > 0).map((m: any) => m.name);
  const absent = active_models.filter((m: any) => (visMap[m.id] ?? 0) === 0).map((m: any) => m.name);
  const tc = (p.top_competitors || [])[0];
  const lines = [
    `*Drift Radar Alert* – prompt »${p.prompt_text}«`,
    `Divergence: ${p.divergence_score.toFixed(2)} · ${p.silence_type ? p.silence_type.replace('_', ' ') + ' silence' : 'active'}`,
    `${own_brand} visible on: ${active.length ? active.join(', ') : '_none_'}`,
    `${own_brand} absent on: ${absent.length ? absent.join(', ') : '_none_'}`,
  ];
  if (tc) lines.push(`Top competitor cited instead: ${tc.brand_name} (${Math.round(tc.max_visibility * 100)}%)`);
  lines.push(`Source: Peec AI MCP · ${date_range.start} → ${date_range.end} · Drift Radar #BuiltWithPeec`);
  return lines.join('\n');
}

function buildClaudePromptText(p: any): string {
  const visMap = p.visibility_by_model || {};
  const visLines = active_models.map((m: any) => `- ${m.name}: ${Math.round((visMap[m.id] ?? 0) * 100)}%`).join('\n');
  const narrative = (p.chat_sample || {}).narrative || '';
  return `Here is AI-search drift data for one of my tracked prompts, pulled from Peec AI MCP over ${date_range.start} – ${date_range.end}.

Prompt: »${p.prompt_text}«
Divergence score: ${p.divergence_score.toFixed(2)} (scale 0 – 1, where 0 = engines agree, 1 = total divergence)
Silence type: ${p.silence_type || 'none'}
Own-brand visibility per engine:
${visLines}

Cross-model narrative: ${narrative}

Please write me a 500-word content brief for this prompt that:
1. Names the stable concepts all engines agree on – these become the content anchors.
2. Identifies the divergent concepts – where the engines disagree, and what each one claims.
3. Lists 3 concrete content moves (own, editorial, citable) to close the gap and gain visibility on the engines where the brand is silent.

Brand: ${own_brand}. Language: match the source prompt.`;
}

function buildLinearDescription(p: any): string {
  const visMap = p.visibility_by_model || {};
  const tc = (p.top_competitors || []).slice(0, 3).map((c: any) => `${c.brand_name} (${Math.round(c.max_visibility * 100)}%)`).join(', ');
  const visLines = active_models.map((m: any) => `- ${m.name}: ${Math.round((visMap[m.id] ?? 0) * 100)}%`).join('\n');
  const silence = p.silence_type;
  let headline: string;
  let actions: string[];
  if (silence === 'own_only') {
    headline = `Drift Radar flagged this prompt as own-only silence. Competitors are cited, ${own_brand} is not.`;
    actions = [
      'Audit top source domains cited by the winning engines',
      'Publish or update a head-to-head comparison page',
      'Add schema.org/Product markup with competitor-equivalent spec fields',
      'Re-measure after 2 weeks',
    ];
  } else if (silence === 'full') {
    headline = `Drift Radar flagged this prompt as full silence. No tracked brand owns the answer across any engine.`;
    actions = [
      'Draft a category-explainer page that answers the prompt on-page',
      'Add it to the editorial queue as a Q&A with schema.org/FAQPage markup',
      'Pitch the explainer to one editorial outlet the engines already cite for the category',
      'Re-measure after 2 weeks',
    ];
  } else {
    headline = `Drift Radar flagged this prompt for high narrative divergence (score ${p.divergence_score.toFixed(2)}). Engines disagree on who the brand is.`;
    actions = [
      'Identify which engine carries the brand and which does not',
      'Stabilise the weak engine: update product pages, fix structured data, close the citation gap',
      'Publish one head-to-head comparison targeting the divergent claim',
      'Re-measure after 2 weeks',
    ];
  }
  const actionLines = actions.map((a) => `- [ ] ${a}`).join('\n');
  return `${headline}

Prompt: »${p.prompt_text}«
Topic: ${p.topic || '-'}
Volume: ${p.volume ?? '-'}
Divergence score: ${p.divergence_score.toFixed(2)}

Own-brand visibility per engine:
${visLines}

Cited instead: ${tc}

Action:
${actionLines}

Source: Peec AI MCP · ${date_range.start} → ${date_range.end} · Drift Radar #BuiltWithPeec`;
}
const ownOnly = prompts
  .filter((p: any) => p.silence_type === 'own_only')
  .sort((a: any, b: any) => volumeBucketRank(b.volume_bucket) - volumeBucketRank(a.volume_bucket));
const fullSilence = prompts
  .filter((p: any) => p.silence_type === 'full')
  .sort((a: any, b: any) => volumeBucketRank(b.volume_bucket) - volumeBucketRank(a.volume_bucket));

const competitorRank = competitors
  .map((c: any) => {
    const totalVis = prompts.reduce((acc: number, p: any) => {
      const comp = (p.top_competitors || []).find((tc: any) => tc.brand_id === c.id);
      return acc + (comp ? comp.max_visibility : 0);
    }, 0);
    const promptCount = prompts.filter((p: any) =>
      (p.top_competitors || []).some((tc: any) => tc.brand_id === c.id)
    ).length;
    return { ...c, total_visibility: totalVis, prompt_count: promptCount };
  })
  .sort((a: any, b: any) => b.total_visibility - a.total_visibility);

function pct(v: number): string {
  return `${Math.round(v * 100)}`;
}
function engineName(id: string): string {
  return active_models.find((m: any) => m.id === id)?.name || id;
}

const CLAIM_TYPES = ['brand', 'substance', 'function', 'condition', 'criterion'] as const;
type ClaimType = typeof CLAIM_TYPES[number];

const ownBrandLower = String(own_brand).toLowerCase();
const competitorNamesLower = competitors.map((c: any) => String(c.name).toLowerCase());

function classifyBrandClaim(text: string): 'own' | 'competitor' | 'unknown' {
  const t = (text || '').toLowerCase();
  if (t.includes(ownBrandLower)) return 'own';
  if (competitorNamesLower.some((n: string) => n && t.includes(n))) return 'competitor';
  return 'unknown';
}

function brandHitInClaim(text: string): 'own' | 'competitor' | null {
  const t = (text || '').toLowerCase();
  if (t.includes(ownBrandLower)) return 'own';
  if (competitorNamesLower.some((n: string) => n && t.includes(n))) return 'competitor';
  return null;
}

function sumCounts(counts: Record<string, number> | undefined): number {
  if (!counts) return 0;
  return Object.values(counts).reduce((a, b) => a + (b || 0), 0);
}
---
<Base title={`Drift Radar – ${project}`}>
  <nav class="tab-nav" aria-label="Sections">
    <div class="tab-nav-inner">
      <a class="tab-brand" href="#overview">
        <span class="tab-brand-name">Drift Radar</span>
        <span class="tab-brand-sub mono">/ {own_brand}</span>
      </a>
