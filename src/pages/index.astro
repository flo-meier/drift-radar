                const w = 160, h = 36, pad = 4;
                const xs = pts.map((_: number, i: number) => pad + (i * (w - 2*pad)) / Math.max(1, pts.length - 1));
                const ys = pts.map((v: number) => h - pad - (v / trendMax) * (h - 2*pad));
                const d = xs.map((x: number, i: number) => `${i === 0 ? 'M' : 'L'} ${x.toFixed(1)} ${ys[i].toFixed(1)}`).join(' ');
                const last = pts[pts.length - 1];
                return (
                  <div class="trend-row">
                    <span class="trend-engine">{m.name}</span>
                    <svg class="trend-svg" viewBox={`0 0 ${w} ${h}`} width={w} height={h} preserveAspectRatio="none">
                      <path d={d} fill="none" stroke="var(--drift)" stroke-width="1.5" />
                      {xs.map((x: number, i: number) => (
                        <circle cx={x} cy={ys[i]} r="2.5" fill="var(--drift)"></circle>
                      ))}
                    </svg>
                    <span class="trend-value mono">{Math.round(last * 100)}%</span>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>

