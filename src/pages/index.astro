  .strip-dek { color: var(--ink-soft); max-width: 760px; margin: 14px auto 0; font-size: clamp(15px, 1.5vw, 17px); font-style: normal; font-family: var(--sans); }
  .strip-wrap { position: relative; max-width: 1100px; margin: 0 auto; padding: 0; }
