  .number-moment { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; padding: 48px 0; align-items: center; }
  @media (max-width: 900px) { .number-moment { grid-template-columns: 1fr; gap: 16px; padding: 32px 0; } }
  .number-unit { font-size: 0.5em; color: var(--ink-soft); margin-left: 6px; font-weight: 500; }
  .number-label { font-size: 17px; line-height: 1.55; }
  .number-label .serif { font-size: 22px; }
  .number-label .mute { color: var(--ink-soft); }

  .section-header-editorial { margin-bottom: 48px; max-width: 780px; }
  .section-header-editorial .kicker { margin-bottom: 10px; }

  .heatmap-section { background: var(--bg); }
  .heatmap-filter { display: flex; flex-wrap: wrap; align-items: center; gap: 10px 12px; margin: 32px 0 0; padding: 18px 20px; background: var(--bg-alt); border: 1px solid var(--rule); }
  .heatmap-filter-secondary { margin-top: 0; border-top: 0; padding-top: 14px; padding-bottom: 14px; background: var(--bg-deep); }
  .heatmap-filter + .heatmap-filter-secondary { border-top: 1px solid var(--rule); }
  .heatmap-filter-secondary + .heatmap { margin-top: 20px; }
  .heatmap-filter-label { margin-right: 12px; color: var(--ink); font-weight: 600; letter-spacing: 0.1em; }
  .filter-tag-btn { text-transform: capitalize; }
  .filter-btn { font-family: var(--sans); font-size: 13px; font-weight: 500; padding: 9px 16px; background: var(--bg); border: 1px solid var(--rule); color: var(--ink-soft); cursor: pointer; transition: all 140ms ease; display: inline-flex; align-items: center; gap: 10px; letter-spacing: 0.01em; }
  .filter-btn:hover { border-color: var(--drift); color: var(--drift); background: var(--bg); }
  .filter-btn:hover .filter-count { color: var(--drift); }
  .filter-btn.is-active { background: var(--drift); border-color: var(--drift); color: var(--bg); box-shadow: 0 2px 8px rgba(184, 74, 47, 0.2); }
  .filter-btn.is-active .filter-count { color: var(--bg); opacity: 0.85; background: rgba(247, 244, 238, 0.18); padding: 2px 6px; }
  .filter-count { font-size: 11px; color: var(--ink-mute); font-weight: 600; padding: 2px 6px; background: var(--bg-alt); transition: background 140ms ease; }
  .filter-btn:hover .filter-count { background: var(--bg-alt); }

  .heatmap-row.has-deepdive { cursor: pointer; position: relative; }
  .heatmap-row.has-deepdive::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: transparent; transition: background 140ms ease; }
  .heatmap-row.has-deepdive:hover { background: var(--drift-soft); }
  .heatmap-row.has-deepdive:hover::before { background: var(--drift); }
  .heatmap-row.has-deepdive:hover .heatmap-score { color: var(--drift); }
  .deepdive-link { font-family: var(--sans); font-weight: 600; font-size: 11px; color: var(--bg); background: var(--drift); text-transform: uppercase; letter-spacing: 0.08em; text-decoration: none; padding: 5px 10px; border: 1px solid var(--drift); border-radius: 0; white-space: nowrap; }
  .deepdive-link:hover { background: var(--ink); border-color: var(--ink); color: var(--bg); text-decoration: none; }

  /* Filter visibility rules */
  body.filter-drifting .heatmap-row:not(.is-drifting) { display: none; }
  body.filter-own-only .heatmap-row:not(.has-competitors) { display: none; }
  body.filter-full-silence .heatmap-row:not(.is-full-silence) { display: none; }
  body.filter-has-deepdive .heatmap-row:not(.has-deepdive) { display: none; }
  .heatmap { border-top: 1px solid var(--ink); border-bottom: 1px solid var(--ink); }
  .heatmap-head { display: grid; grid-template-columns: 80px repeat(3, 150px) 1fr; border-bottom: 1px solid var(--rule-strong); background: var(--bg-alt); }
  .heatmap-head-cell { padding: 14px 16px; font-family: var(--sans); font-size: 11px; font-weight: 600; color: var(--ink-soft); letter-spacing: 0.12em; text-transform: uppercase; }
  .heatmap-score-col { text-align: right; padding-right: 20px; }
  .heatmap-prompt-col { padding-left: 20px; }
  .heatmap-row { display: grid; grid-template-columns: 80px repeat(3, 150px) 1fr; border-bottom: 1px solid var(--rule); transition: background 120ms ease; }
  .heatmap-row:last-child { border-bottom: none; }
  .heatmap-row:hover { background: var(--bg-alt); }
  .heatmap-row.has-competitors .heatmap-score { color: var(--drift); }
  .heatmap-cell { padding: 18px 16px; display: flex; align-items: center; }
  .heatmap-score { font-family: var(--mono); font-weight: 700; font-size: 16px; color: var(--ink); justify-content: flex-end; padding-right: 20px; }
  .heatmap-bar-cell { flex-direction: column; align-items: stretch; justify-content: center; gap: 6px; padding: 18px 14px; }
  .heatmap-bar-track { height: 8px; background: var(--bg-alt); border: 1px solid var(--rule); position: relative; }
  .heatmap-bar-fill { position: absolute; top: 0; left: 0; bottom: 0; background: var(--drift); opacity: 0.85; }
  .has-competitors .heatmap-bar-fill { background: var(--drift); }
  .heatmap-row.is-full-silence .heatmap-bar-fill { background: var(--ink-mute); }
  .heatmap-bar-val { font-family: var(--mono); font-size: 11px; color: var(--ink-soft); letter-spacing: 0.02em; }
  .heatmap-prompt { flex-direction: column; align-items: flex-start; gap: 6px; padding: 18px 20px; }
  .prompt-text { font-family: var(--serif); font-size: 17px; line-height: 1.35; color: var(--ink); }
  .prompt-meta { font-family: var(--sans); font-size: 12px; color: var(--ink-mute); letter-spacing: 0.02em; }
  .prompt-meta em { color: var(--ink-soft); }

  .deepdive-section { padding-top: 96px; padding-bottom: 96px; }
  .deepdive { padding: 56px 0; border-top: 1px solid var(--rule); }
  .deepdive:first-of-type { border-top: 1px solid var(--ink); }
  .deepdive:last-of-type { border-bottom: 1px solid var(--ink); }
  .deepdive-header { display: grid; grid-template-columns: 300px 1fr; gap: 40px; margin-bottom: 40px; align-items: start; }
  @media (max-width: 900px) { .deepdive-header { grid-template-columns: 1fr; gap: 16px; } }
  .deepdive-score-block { padding-top: 4px; }
  .deepdive-score-block .typo-number { font-size: clamp(72px, 8.4vw, 108px); line-height: 0.92; }
  .deepdive-prompt { font-style: italic; font-size: clamp(24px, 3vw, 32px); line-height: 1.3; font-weight: 500; }
  /* Wilson-CI band per deep-dive engine */
  .deepdive-ci { display: flex; flex-direction: column; gap: 4px; margin-top: -4px; }
  .deepdive-ci-track { position: relative; height: 10px; background: linear-gradient(to right, var(--rule) 0 100%); border-radius: 2px; }
  .deepdive-ci-band { position: absolute; top: 2px; bottom: 2px; background: var(--drift-soft); border-left: 1px solid var(--drift); border-right: 1px solid var(--drift); }
  .deepdive-ci-point { position: absolute; top: -2px; bottom: -2px; width: 2px; background: var(--drift); transform: translateX(-1px); }
  .deepdive-col.is-hero .deepdive-ci-band { background: rgba(62, 92, 46, 0.18); border-color: var(--own); }
  .deepdive-col.is-hero .deepdive-ci-point { background: var(--own); }
  .deepdive-ci-label { font-size: 10px; color: var(--ink-mute); letter-spacing: 0.04em; }

  .deepdive-columns { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  @media (max-width: 900px) { .deepdive-columns { grid-template-columns: 1fr; gap: 24px; } }
  .deepdive-col { padding-top: 20px; border-top: 2px solid var(--ink); display: flex; flex-direction: column; gap: 16px; min-height: 280px; }
  .deepdive-col.is-hero { border-top-color: var(--own); }
  .deepdive-col.is-silent { border-top-color: var(--rule-strong); }
  .deepdive-col.is-nodata { border-top-color: var(--rule); }
  .deepdive-col-head { display: flex; justify-content: space-between; align-items: baseline; padding-bottom: 12px; border-bottom: 1px solid var(--rule); }
  .deepdive-engine { font-family: var(--serif); font-weight: 700; font-size: 16px; color: var(--ink); letter-spacing: 0.02em; }
  .deepdive-col.is-hero .deepdive-engine { color: var(--own); }
  .deepdive-vis { font-size: 15px; font-weight: 500; color: var(--ink-soft); }
  .deepdive-col.is-hero .deepdive-vis { color: var(--own); font-weight: 700; }
  .deepdive-brands { }
  .deepdive-brand-list { margin-top: 8px; display: flex; flex-direction: column; gap: 3px; font-family: var(--serif); font-size: 15px; }
  .brand-name.is-own { color: var(--own); font-weight: 700; }
  .brand-name.is-competitor { color: var(--competitor); font-weight: 500; }
  .deepdive-quote { margin: 12px 0 0; padding: 0; padding-left: 14px; border-left: 2px solid var(--rule-strong); font-family: var(--serif); font-style: italic; font-size: 14px; line-height: 1.5; color: var(--ink-soft); white-space: pre-wrap; }
  .deepdive-col.is-hero .deepdive-quote { border-left-color: var(--own); }

  /* Narrative Matrix (Metrik 3 – Claim-Type Distribution) */
  .narrative-matrix { margin: 8px 0 40px; padding: 28px 0 32px; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
  .narrative-matrix-head { display: flex; justify-content: space-between; align-items: baseline; gap: 24px; flex-wrap: wrap; margin-bottom: 20px; }
  .narrative-matrix-legend { display: flex; gap: 14px; flex-wrap: wrap; }
  .narrative-matrix-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  @media (max-width: 900px) { .narrative-matrix-grid { grid-template-columns: 1fr; gap: 20px; } }
  .narrative-matrix-col { display: flex; flex-direction: column; gap: 10px; }
  .narrative-matrix-engine { font-family: var(--serif); font-weight: 600; font-size: 14px; color: var(--ink-soft); letter-spacing: 0.02em; }
  .narrative-matrix-bar { display: flex; height: 14px; background: var(--bg-alt); border: 1px solid var(--rule); overflow: hidden; }
  .narrative-matrix-bar .mono { padding: 0 10px; align-self: center; font-size: 11px; }
  .narrative-matrix-seg { display: block; height: 100%; min-width: 2px; }
  .narrative-matrix-counts { display: flex; flex-wrap: wrap; gap: 12px 16px; font-size: 12px; color: var(--ink-mute); }
  .narrative-matrix-count { letter-spacing: 0.02em; }
  .narrative-matrix-count .text-type-brand { color: var(--drift); font-weight: 600; }
  .narrative-matrix-count .text-type-substance { color: var(--own); font-weight: 600; }
  .narrative-matrix-count .text-type-function { color: var(--ink); font-weight: 600; }
  .narrative-matrix-count .text-type-condition { color: var(--competitor); font-weight: 600; }
  .narrative-matrix-count .text-type-criterion { color: var(--warn); font-weight: 600; }

  /* Claim chips (legend + matrix segments) */
  .claim-chip { display: inline-flex; align-items: center; gap: 6px; font-family: var(--sans); font-size: 11px; font-weight: 500; color: var(--ink-soft); letter-spacing: 0.04em; text-transform: uppercase; }
  .claim-chip .claim-chip-dot { width: 9px; height: 9px; display: inline-block; border-radius: 50%; }
  .claim-chip-brand .claim-chip-dot, .narrative-matrix-seg.claim-chip-brand { background: var(--drift); }
  .claim-chip-substance .claim-chip-dot, .narrative-matrix-seg.claim-chip-substance { background: var(--own); }
  .claim-chip-function .claim-chip-dot, .narrative-matrix-seg.claim-chip-function { background: var(--ink); }
  .claim-chip-condition .claim-chip-dot, .narrative-matrix-seg.claim-chip-condition { background: var(--competitor); }
  .claim-chip-criterion .claim-chip-dot, .narrative-matrix-seg.claim-chip-criterion { background: var(--warn); }

  /* Per-column claim list */
  .deepdive-claims { margin-top: 4px; }
  .claim-list { list-style: none; margin: 8px 0 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .claim { display: grid; grid-template-columns: 72px 1fr; gap: 10px; font-size: 13.5px; line-height: 1.4; padding-top: 6px; border-top: 1px dashed var(--rule); }
  .claim:first-child { border-top: none; padding-top: 0; }
  .claim-label { font-family: var(--sans); font-size: 10px; font-weight: 600; color: var(--ink-mute); letter-spacing: 0.1em; text-transform: uppercase; padding-top: 3px; }
  .claim-text { font-family: var(--serif); color: var(--ink); font-size: 14.5px; }
  .claim-type-substance .claim-label { color: var(--own); }
  .claim-type-substance .claim-text { color: var(--own); font-weight: 600; }
  .claim-type-function .claim-label { color: var(--ink-soft); }
  .claim-type-condition .claim-label { color: var(--competitor); }
  .claim-type-condition .claim-text { font-style: italic; color: var(--ink-soft); }
  .claim-type-criterion .claim-label { color: var(--warn); }
  .claim-type-criterion .claim-text { font-style: italic; color: var(--ink-soft); }
  .claim-type-brand .claim-label { color: var(--drift); }
  .claim-type-brand.claim-brand-own .claim-text { color: var(--own); font-weight: 700; }
  .claim-type-brand.claim-brand-competitor .claim-text { color: var(--competitor); font-weight: 500; }
  .claim-type-brand.claim-brand-unknown .claim-text { color: var(--drift); font-style: italic; }
  .claim-type-brand.claim-brand-unknown .claim-text::after { content: ' · untracked'; font-family: var(--sans); font-size: 10px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--drift); opacity: 0.7; }
  /* Brand hit within non-brand claim (e.g. substance claim mentioning Pferdegold) */
  .claim.claim-brandhit-own .claim-text { color: var(--own); font-weight: 600; }
  .claim.claim-brandhit-competitor .claim-text { color: var(--competitor); font-weight: 500; }

  .competitors-section { padding: 96px 0; background: var(--bg-alt); }
  .competitor-table { border-top: 1px solid var(--ink); border-bottom: 1px solid var(--ink); }
  .competitor-head { display: grid; grid-template-columns: 1.5fr 80px 180px 1fr; padding: 14px 0; border-bottom: 1px solid var(--rule-strong); font-family: var(--sans); font-size: 11px; font-weight: 600; color: var(--ink-soft); letter-spacing: 0.12em; text-transform: uppercase; }
  .competitor-row { display: grid; grid-template-columns: 1.5fr 80px 180px 1fr; align-items: center; padding: 20px 0; border-bottom: 1px solid var(--rule); }
  .competitor-row:last-child { border-bottom: none; }
  .competitor-row.own-row { background: var(--own-soft); margin: 0 -16px; padding: 20px 16px; border-bottom: 1px solid var(--rule); }
  .competitor-name { font-size: 22px; font-weight: 600; color: var(--ink); }
  .competitor-row.own-row .competitor-name { color: var(--own); }
  .competitor-bar { display: flex; align-items: center; }
  .competitor-bar-track { flex: 1; height: 6px; background: var(--bg-deep); border: 1px solid var(--rule); }
  .competitor-bar-fill { height: 100%; background: var(--competitor); opacity: 0.9; }
  .competitor-bar-fill.own-fill { background: var(--own); }
  @media (max-width: 900px) {
    .competitor-head, .competitor-row { grid-template-columns: 1fr 1fr; gap: 8px; }
    .competitor-head > *:nth-child(3), .competitor-row > *:nth-child(3) { display: none; }
  }

  .ownonly-section { padding: 96px 0; }
  .stanza-list { display: flex; flex-direction: column; }
  .stanza { padding: 32px 0; border-top: 1px solid var(--rule); }
  .stanza:first-child { border-top: 1px solid var(--ink); }
  .stanza:last-child { border-bottom: 1px solid var(--ink); }
  .stanza-prompt { font-family: var(--serif); font-style: italic; font-size: 22px; line-height: 1.35; font-weight: 500; color: var(--ink); }
  .stanza-meta { font-size: 13px; color: var(--ink-mute); margin-top: 6px; font-family: var(--sans); letter-spacing: 0.02em; }
  .stanza-cited { margin-top: 14px; font-size: 15px; font-family: var(--sans); }

  .full-silence-section { padding: 96px 0; background: var(--bg-alt); }
  .plain-list { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--ink); border-bottom: 1px solid var(--ink); }
  .plain-list li { padding: 16px 0; border-bottom: 1px solid var(--rule); }
  .plain-list li:last-child { border-bottom: none; }

  .methodology { padding: 96px 0; }
  .methodology-body { display: grid; grid-template-columns: 1fr 1fr; gap: 48px 64px; }
  @media (max-width: 900px) { .methodology-body { grid-template-columns: 1fr; gap: 32px; } }
  .method-block { padding: 24px 0; border-top: 1px solid var(--rule); }
  .method-block:nth-child(-n+2) { border-top: 1px solid var(--ink); }
  .method-block p { color: var(--ink-soft); font-size: 15px; line-height: 1.6; }

  /* Peec-native actions grid */
  .peec-actions-section { padding: 96px 0; }
  .peec-actions-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-top: 40px; }
  @media (max-width: 900px) { .peec-actions-grid { grid-template-columns: 1fr; gap: 20px; } }
  .peec-action-card { padding: 28px 30px; border-left: 3px solid var(--own); background: var(--bg-alt); display: flex; flex-direction: column; }
  .peec-action-meta { display: flex; justify-content: space-between; align-items: baseline; gap: 20px; font-family: var(--sans); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-mute); }
  .peec-action-scope { font-weight: 600; color: var(--own); }
  .peec-action-score { font-size: 11px; letter-spacing: 0.02em; text-transform: none; color: var(--ink-soft); font-family: var(--mono); }
  .peec-action-text { font-family: var(--serif); font-size: 17px; line-height: 1.5; color: var(--ink); margin-top: 16px; flex: 1; }
  .peec-action-link { display: inline-block; margin-top: 18px; font-size: 12px; color: var(--ink-soft); text-decoration: none; border-bottom: 1px dashed var(--rule-strong); padding-bottom: 2px; word-break: break-word; }
  .peec-action-link:hover { color: var(--drift); border-bottom-color: var(--drift); }

  /* Limitations grid */
  .limit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; margin-top: 40px; }
  @media (max-width: 900px) { .limit-grid { grid-template-columns: 1fr; gap: 20px; } }
  .limit-card { padding: 32px 30px 28px; background: var(--bg-alt); border-left: 3px solid var(--warn); }
  .limit-kicker { font-family: var(--sans); font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--warn); }
  .limit-title { font-family: var(--serif); font-size: 22px; font-weight: 600; line-height: 1.3; margin: 8px 0 14px; color: var(--ink); }
  .limit-body { color: var(--ink-soft); font-size: 15px; line-height: 1.6; }
  .limit-body code { background: var(--bg); padding: 2px 6px; border-radius: 2px; color: var(--ink); font-size: 0.9em; }

  /* Divergence-score helpers */
  .heatmap-score { cursor: help; }
  .deepdive-score-block { cursor: help; }
  .drift-score-legend { font-family: var(--mono); font-size: 11px; color: var(--ink-mute); letter-spacing: 0.02em; margin-top: 6px; }
  .method-block code { background: var(--bg-alt); padding: 2px 5px; border: 1px solid var(--rule); font-size: 0.88em; white-space: nowrap; }
  .formula { font-family: var(--mono); font-size: 13px; padding: 12px 14px; background: var(--bg-alt); border-left: 2px solid var(--drift); color: var(--ink); white-space: pre-wrap; margin: 12px 0 0; overflow-x: auto; }

  /* Tab-scoped export strip – sits inside each tab section */
  .tab-export-strip { display: flex; flex-wrap: wrap; align-items: center; gap: 10px 16px; padding: 12px 0 0; margin-top: 24px; border-top: 1px dashed var(--rule-strong); font-family: var(--sans); font-size: 13px; }
  .tab-export-strip .eyebrow { margin-right: 6px; letter-spacing: 0.1em; color: var(--ink); }
  .tab-export-link { display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; background: var(--bg); border: 1px solid var(--rule); color: var(--ink-soft); text-decoration: none; transition: all 140ms ease; font-size: 12px; font-weight: 500; }
  .tab-export-link:hover { border-color: var(--drift); color: var(--drift); background: var(--bg-alt); text-decoration: none; }
  .tab-export-link .mono { font-size: 11px; font-weight: 700; color: var(--drift); padding: 2px 6px; background: var(--bg-alt); }
  .tab-export-link:hover .mono { background: var(--drift); color: var(--bg); }

  .stanza-brief-link { font-family: var(--sans); font-size: 11px; font-weight: 600; color: var(--drift); text-decoration: none; letter-spacing: 0.05em; }
  .stanza-brief-link:hover { color: var(--ink); text-decoration: underline; }

  /* Brief group accordion (Export Kit tab) */
  .brief-group { margin-bottom: 12px; border: 1px solid var(--rule); background: var(--bg-alt); }
  .brief-group summary { list-style: none; cursor: pointer; padding: 16px 22px; display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap; }
  .brief-group summary::-webkit-details-marker { display: none; }
  .brief-group summary::before { content: '›'; font-family: var(--mono); font-weight: 700; font-size: 18px; color: var(--drift); transition: transform 120ms ease; }
  .brief-group[open] summary::before { transform: rotate(90deg); }
  .brief-group-kind { font-family: var(--sans); font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--drift); padding: 3px 10px; background: rgba(184, 74, 47, 0.08); }
  .brief-group-title { font-family: var(--serif); font-weight: 700; font-size: 18px; color: var(--ink); flex: 1; }
  .brief-group-count { font-size: 12px; color: var(--ink-mute); }
  .brief-group[open] summary { border-bottom: 1px solid var(--rule); }
  .brief-group .export-brief-list { margin: 0; padding: 0 22px 16px; }
  .brief-group .export-brief-list li a { font-family: var(--serif); font-size: 14px; }

  /* Export kit */
  .exports-section { padding: 96px 0; background: var(--bg); }
