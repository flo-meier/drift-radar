            <span class="legend-swatch legend-swatch-bar"></span>
            <div>
              <strong>Bar length</strong>
              <span>own-brand visibility for that engine (0–100 %). »–« = no brand mention captured.</span>
            </div>
          </div>
          <div class="legend-item">
            <span class="legend-swatch legend-swatch-ownonly"></span>
            <div>
              <strong>Own-only silence</strong>
              <span>competitors are cited, you are not. Content priority: close the narrative gap.</span>
            </div>
          </div>
          <div class="legend-item">
            <span class="legend-swatch legend-swatch-fullsilence"></span>
            <div>
              <strong>Full silence</strong>
              <span>no brand cited by anyone. First-mover real estate: nobody owns this answer yet.</span>
            </div>
          </div>
          <div class="legend-item">
            <span class="legend-swatch legend-swatch-deepdive">▸</span>
            <div>
              <strong>Deep-dive link</strong>
              <span>click »Deep dive →« or any row with the chevron marker to jump to the full narrative comparison.</span>
            </div>
          </div>
        </div>
      </div>

      <nav class="heatmap-filter" aria-label="Filter heatmap">
        <span class="eyebrow heatmap-filter-label">Filter</span>
        <button type="button" class="filter-btn is-active" data-filter="all">All <span class="filter-count mono">{heatmapRows.length}</span></button>
        <button type="button" class="filter-btn" data-filter="drifting">Drifting ≥ 0.30 <span class="filter-count mono">{heatmapRows.filter((r: any) => r.divergence_score >= 0.3).length}</span></button>
        <button type="button" class="filter-btn" data-filter="own-only">Own-only silence <span class="filter-count mono">{heatmapRows.filter((r: any) => r.silence_type === 'own_only').length}</span></button>
        <button type="button" class="filter-btn" data-filter="full-silence">Full silence <span class="filter-count mono">{heatmapRows.filter((r: any) => r.silence_type === 'full').length}</span></button>
        <button type="button" class="filter-btn" data-filter="has-deepdive">With deep dive <span class="filter-count mono">{heatmapRows.filter((r: any) => deepDivePromptIds.has(r.prompt_id)).length}</span></button>
      </nav>

      <nav class="heatmap-filter heatmap-filter-secondary" aria-label="Tag filter">
        <span class="eyebrow heatmap-filter-label">Peec tags</span>
        <button type="button" class="filter-btn filter-tag-btn is-active" data-tag="all">All <span class="filter-count mono">{heatmapRows.length}</span></button>
        {(data as any).tags?.map((tg: any) => (
          <button type="button" class="filter-btn filter-tag-btn" data-tag={tg.name}>
            {tg.name} <span class="filter-count mono">{heatmapRows.filter((r: any) => r.tag_names?.includes(tg.name)).length}</span>
          </button>
        ))}
      </nav>

      <div class="heatmap">
        <div class="heatmap-head">
          <div class="heatmap-cell heatmap-head-cell heatmap-score-col">Drift</div>
          {active_models.map((m: any) => (
            <div class="heatmap-cell heatmap-head-cell">{m.name}</div>
          ))}
          <div class="heatmap-cell heatmap-head-cell heatmap-prompt-col">Prompt</div>
        </div>
        {heatmapRows.map((row: any) => (
          <div
            class={`heatmap-row${row.silence_type === 'own_only' ? ' has-competitors' : ''}${row.silence_type === 'full' ? ' is-full-silence' : ''}${row.divergence_score >= 0.3 ? ' is-drifting' : ''}${deepDivePromptIds.has(row.prompt_id) ? ' has-deepdive' : ''}`}
            data-deepdive-href={deepDivePromptIds.has(row.prompt_id) ? `#deepdive-${row.prompt_id}` : undefined}
            data-tags={(row.tag_names || []).join(',')}
          >
            <div
              class="heatmap-cell heatmap-score"
              title={`Divergence score ${row.divergence_score.toFixed(2)} · formula: 0.7 · (max(vis) − min(vis)) + 0.3 · clamp(CV, 0, 2)/2 · range ${row.range_visibility.toFixed(2)}, CV ${row.cv_visibility.toFixed(2)}`}
            >{row.divergence_score.toFixed(2)}</div>
            {active_models.map((m: any) => {
              const v = row.visibility_by_model[m.id];
              const barWidth = Math.max(v * 100, v > 0 ? 3 : 0);
              return (
                <div class="heatmap-cell heatmap-bar-cell">
                  <span class="heatmap-bar-engine">{m.name}</span>
                  <div class="heatmap-bar-track">
                    {v > 0 && (
                      <div class="heatmap-bar-fill" style={`width: ${barWidth}%`}></div>
                    )}
                  </div>
                  <span class="heatmap-bar-val">{v === 0 ? '–' : pct(v) + '%'}</span>
                </div>
              );
            })}
            <div class="heatmap-cell heatmap-prompt">
              <div class="prompt-text">{row.prompt_text}</div>
              <div class="prompt-meta">
                <span>{row.topic}</span>
                {row.volume_bucket && <span title="Peec search-volume bucket (very low / low / medium / high / very high)">&nbsp;·&nbsp; volume {row.volume_bucket}</span>}
                {row.silence_type === 'own_only' && (
                  <span>&nbsp;·&nbsp; <em class="text-competitor">own-only silence – {row.top_competitors.slice(0, 3).map((c: any) => c.brand_name).join(', ')} cited instead</em></span>
                )}
                {row.silence_type === 'full' && (
                  <span>&nbsp;·&nbsp; <em class="text-mute">full silence – category is brand-neutral</em></span>
                )}
                {deepDivePromptIds.has(row.prompt_id) && (
                  <span>&nbsp;·&nbsp; <a class="deepdive-link" href={`#deepdive-${row.prompt_id}`}>Deep dive →</a></span>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="tab-export-strip">
        <span class="eyebrow">Export this section</span>
        <a class="tab-export-link" href="/downloads/drift_radar.csv" download><span class="mono">CSV</span> all 50 prompts</a>
        <a class="tab-export-link" href="/downloads/heatmap_drift.csv" download><span class="mono">CSV</span> drifting ≥ 0.30 only</a>
        <a class="tab-export-link" href="/downloads/drift_radar.json" download><span class="mono">JSON</span> raw pipeline</a>
      </div>
      <p class="caption" style="margin-top: 24px;">Showing the 20 most drifting prompts. Full dataset: {prompts.length} prompts.</p>
    </div>
  </section>

  <section class="section deepdive-section" data-tab="deepdives">
    <div class="container">
      <div class="section-header-editorial">
        <div>
          <div class="kicker">Deep dive</div>
          <h2>Same question, three answers</h2>
          <p class="caption" style="margin-top: 12px; max-width: 720px;">
            Five maximum-drift prompts, literal model outputs side by side. One engine places {own_brand} first, another recommends a competitor, a third invents brands that do not exist, a fourth answers in pure substance mode and never names anyone.
          </p>
        </div>
      </div>

      <div class="legend-box legend-box-dd">
        <div class="legend-title">How to read a deep dive</div>
        <div class="legend-grid legend-grid-dd">
          <div class="legend-item">
            <span class="legend-swatch legend-swatch-drift">0.91</span>
            <div>
              <strong>Divergence score</strong>
              <span>0.7 × range(visibility) + 0.3 × clamp(CV, 0, 2) / 2. Above 0.30 is »narrative is breaking«, above 0.60 is »three different stories«.</span>
            </div>
          </div>
          <div class="legend-item">
            <span class="legend-swatch legend-swatch-ci">├─┤</span>
            <div>
              <strong>Wilson 95 % CI bar</strong>
              <span>honest visibility range for N = 3 chats. A thin bar means the signal is certain; a bar spanning 0–0.56 means »could be anything between zero and majority«.</span>
            </div>
          </div>
          <div class="legend-item">
            <span class="legend-swatch legend-swatch-silent">0 %</span>
            <div>
              <strong>Column with 0 %</strong>
              <span>the engine simply did not mention the brand in the sampled chat. Not »wrong« – absent.</span>
            </div>
          </div>
          <div class="legend-item">
            <span class="legend-swatch legend-swatch-hero">100 %</span>
            <div>
              <strong>Column with high %</strong>
              <span>the engine placed the brand prominently. Combined with a 0 % peer column, it is the divergence pattern at a glance.</span>
            </div>
          </div>
        </div>
      </div>

      {deepDives.map((p: any, ddIdx: number) => (
        <article class="deepdive" id={`deepdive-${p.prompt_id}`} data-dd-index={ddIdx}>
          <header class="deepdive-header">
            <div
              class="deepdive-score-block"
              title={`Divergence = 0.7 · (max(vis) − min(vis)) + 0.3 · clamp(CV, 0, 2)/2 · range ${p.range_visibility.toFixed(2)}, CV ${p.cv_visibility.toFixed(2)}`}
            >
              <div class="eyebrow">Divergence score</div>
              <div class="typo-number drift" style="margin-top: 4px;">{p.divergence_score.toFixed(2)}</div>
              <div class="drift-score-legend">range {p.range_visibility.toFixed(2)} · CV {p.cv_visibility.toFixed(2)}</div>
              <div class="drift-score-reading mono">{p.divergence_score >= 0.80 ? 'three non-overlapping answers' : p.divergence_score >= 0.50 ? 'two versions compete' : p.divergence_score >= 0.30 ? 'narrative is drifting' : 'engines aligned'}</div>
            </div>
            <div class="deepdive-title">
              <h3 class="deepdive-prompt">»{p.prompt_text}«</h3>
              <p class="dek" style="font-size: 18px; margin-top: 12px;">{p.chat_sample.narrative}</p>
              <div class="deepdive-meta">
                <span class="deepdive-meta-item"><span class="eyebrow">Topic</span><span>{p.topic || '–'}</span></span>
                <span class="deepdive-meta-item"><span class="eyebrow" title="Peec search-volume bucket">Volume</span><span>{p.volume_bucket || '–'}</span></span>
                {p.tag_names && p.tag_names.length > 0 && (
                  <span class="deepdive-meta-item"><span class="eyebrow">Tags</span><span>{p.tag_names.join(' · ')}</span></span>
                )}
              </div>
              {ddIdx > 0 && (
                <button type="button" class="deepdive-mobile-toggle" data-dd-toggle aria-expanded="false">
                  <span class="deepdive-mobile-toggle-label">Tap to expand</span>
                  <span class="deepdive-mobile-toggle-chev" aria-hidden="true">↓</span>
                </button>
              )}
            </div>
          </header>

          <div class="deepdive-body">

          {(p.search_queries?.length > 0 || p.shopping_queries?.length > 0) && (
            <div class="search-intent-block">
              <div class="search-intent-head">
                <span class="eyebrow">Real search fan-out · behind this prompt</span>
                <span class="search-intent-note">Peec captured the actual sub-queries and shopping lookups the engines issued to answer this prompt. Every row is a content anchor.</span>
              </div>
              {p.search_queries?.length > 0 && (
                <div class="search-intent-group">
                  <div class="search-intent-label">Search queries</div>
                  <ul class="search-intent-list">
                    {p.search_queries.slice(0, 6).map((q: any) => (
                      <li class="mono">{q.query}</li>
                    ))}
                  </ul>
                </div>
              )}
              {p.shopping_queries?.length > 0 && (
                <div class="search-intent-group">
                  <div class="search-intent-label">Products surfaced</div>
                  <ul class="search-intent-products">
                    {p.shopping_queries.slice(0, 3).map((sq: any) => (
                      <li>
                        <span class="mono search-intent-q">{sq.query}</span>
                        <span class="search-intent-prod">{sq.products.slice(0, 6).join(' · ')}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          )}

          {p.source_mix && p.source_mix.total_retrieved > 0 && (
            <div class="source-mix-block">
              <div class="source-mix-head">
                <div class="eyebrow">Citation sources for this prompt</div>
                <div class="source-mix-meta mono">{p.source_mix.top_domains.length} domains · retrieval weight {p.source_mix.total_retrieved.toFixed(2)}</div>
              </div>
              <div class="source-overview-bar source-mix-bar">
                {SOURCE_CLASS_ORDER.map((cls: string) => {
                  const share = p.source_mix.by_class_normalized?.[cls];
                  if (!share || !(share > 0)) return null;
                  const pct = (share * 100);
                  return <span class={`source-seg source-seg-${cls.toLowerCase()}`} style={`flex-basis: ${pct}%`} title={`${SOURCE_CLASS_LABELS[cls]}: ${pct.toFixed(1)}%`}></span>;
                })}
              </div>
              <div class="source-mix-counts">
                {SOURCE_CLASS_ORDER.map((cls: string) => {
                  const share = p.source_mix.by_class_normalized?.[cls];
                  if (!share || !(share > 0)) return null;
                  const pct = (share * 100);
                  return (
                    <span class={`source-mix-count source-legend-${cls.toLowerCase()}`}>
                      <span class="source-dot"></span>
                      <span class="source-label">{SOURCE_CLASS_LABELS[cls]}</span>
                      <span class="mono">{pct.toFixed(0)}%</span>
                    </span>
                  );
                })}
              </div>
              <details class="source-domains-panel">
                <summary><span class="eyebrow">Top domains cited</span></summary>
                <ul class="source-domains-list">
                  {p.source_mix.top_domains.map((d: any) => (
                    <li class={`source-domain source-legend-${String(d.classification || 'other').toLowerCase()}`}>
                      <span class="source-dot"></span>
                      <span class="source-domain-name mono">{d.domain}</span>
                      <span class="source-domain-class">{SOURCE_CLASS_LABELS[d.classification] || d.classification || 'Other'}</span>
                      <span class="source-domain-rp mono">retrieved {Math.round(d.retrieved_percentage * 100)}%</span>
                    </li>
                  ))}
                </ul>
              </details>
            </div>
          )}

          {p.gap_urls && p.gap_urls.length > 0 && (
            <div class="gap-urls-block">
              <div class="gap-urls-head">
                <div class="eyebrow">URL gap · cited for competitors, not for you</div>
                <div class="gap-urls-count mono">{p.gap_urls.length} URLs</div>
              </div>
              <p class="caption gap-urls-caption">
                Source URLs engines retrieved and cited in competitor-named answers for this prompt, but never next to {own_brand}. Every row is an earned-placement target for outreach, guest content, or retailer placement.
              </p>
              <ul class="gap-urls-list">
                {p.gap_urls.slice(0, 5).map((u: any) => (
                  <li class="gap-url-item">
                    <a class="gap-url-title" href={u.url} target="_blank" rel="noopener">{u.title || u.url}</a>
                    <div class="gap-url-meta mono">
                      <span class="gap-url-class">{(u.url_classification || u.classification || 'OTHER').replace('_', ' ').toLowerCase()}</span>
                      <span> · cited {u.citation_count}× · retrieved {u.retrieval_count}×</span>
                    </div>
                    <div class="gap-url-href mono">{u.url}</div>
                    {u.excerpt && (
                      <div class="gap-url-excerpt">
                        <div class="gap-url-excerpt-label">What this page is saying</div>
                        <p class="gap-url-excerpt-body">{u.excerpt}</p>
                        {u.angle && (
                          <p class="gap-url-excerpt-angle"><strong class="serif">Why it ranks.</strong> {u.angle}</p>
                        )}
                      </div>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          )}

          {p.chat_sample.claim_summary && (
            <div class="narrative-matrix">
              <div class="narrative-matrix-head">
                <div class="eyebrow">Narrative mix · claim-type distribution per engine</div>
                <div class="narrative-matrix-legend">
                  {CLAIM_TYPES.map((t: ClaimType) => (
                    <span class={`claim-chip claim-chip-${t}`}><span class="claim-chip-dot"></span>{t}</span>
                  ))}
                </div>
              </div>
              <div class="narrative-matrix-grid">
                {active_models.map((m: any) => {
                  const counts = p.chat_sample.claim_summary.type_counts_by_model?.[m.id];
                  const total = sumCounts(counts);
                  return (
                    <div class="narrative-matrix-col">
                      <div class="narrative-matrix-engine">{m.name}</div>
                      {total === 0 ? (
                        <div class="narrative-matrix-bar"><span class="mono text-mute">no answer in window</span></div>
                      ) : (
                        <>
                          <div class="narrative-matrix-bar">
                            {CLAIM_TYPES.map((t: ClaimType) => {
                              const n = counts?.[t] || 0;
                              if (n === 0) return null;
                              const width = (n / total * 100);
                              return <span class={`narrative-matrix-seg claim-chip-${t}`} style={`flex-basis: ${width}%`} title={`${n} ${t} claim${n > 1 ? 's' : ''}`}></span>;
                            })}
                          </div>
                          <div class="narrative-matrix-counts">
                            {CLAIM_TYPES.filter((t: ClaimType) => (counts?.[t] || 0) > 0).map((t: ClaimType) => (
                              <span class="narrative-matrix-count mono">{counts[t]} <span class={`text-type-${t}`}>{t}</span></span>
                            ))}
                          </div>
                        </>
                      )}
                    </div>
                  );
                })}
              </div>
              {(p.chat_sample.claim_summary.shared_substances?.length > 0 || p.chat_sample.claim_summary.shared_criteria?.length > 0) && (
                <p class="caption" style="margin-top: 20px;">
                  <strong class="serif">Stable across engines:</strong>&nbsp;
                  {p.chat_sample.claim_summary.shared_substances?.length > 0 && (
                    <span>substance claims <em>({p.chat_sample.claim_summary.shared_substances.join(', ')})</em></span>
                  )}
                  {p.chat_sample.claim_summary.shared_substances?.length > 0 && p.chat_sample.claim_summary.shared_criteria?.length > 0 && <span>&nbsp;·&nbsp;</span>}
                  {p.chat_sample.claim_summary.shared_criteria?.length > 0 && (
                    <span>criterion claims <em>({p.chat_sample.claim_summary.shared_criteria.join(', ')})</em></span>
                  )}
                </p>
              )}
            </div>
          )}

          <div class="share-row" data-share-row>
            <span class="eyebrow share-row-label">Share / send to</span>
            <div class="share-row-actions">
              <button
                type="button"
                class="share-btn share-btn-markdown"
                data-clipboard-text={buildMarkdown(p)}
                data-toast="Copied as Markdown"
              >Copy as Markdown</button>

              <a
                class="share-btn share-btn-claude"
                href={`https://claude.ai/new?q=${encodeURIComponent(buildClaudePromptText(p))}`}
                target="_blank"
                rel="noopener"
              >Open in Claude</a>

              <a
                class="share-btn share-btn-chatgpt"
                href={`https://chatgpt.com/?q=${encodeURIComponent(buildClaudePromptText(p))}`}
                target="_blank"
                rel="noopener"
              >Open in ChatGPT</a>

              <button
                type="button"
                class="share-btn share-btn-notion"
                data-clipboard-text={buildMarkdown(p)}
                data-open-url="https://www.notion.so/new"
                data-toast="Markdown copied for Notion"
              >Copy + open Notion</button>

              <button
                type="button"
                class="share-btn share-btn-gdocs"
                data-clipboard-text={buildMarkdown(p)}
                data-open-url="https://docs.google.com/document/create"
                data-toast="Markdown copied for Google Docs"
              >Copy + open Google Docs</button>

              <a
                class="share-btn share-btn-linear"
                href={`https://linear.app/new?title=${encodeURIComponent(`Drift Radar · ${p.prompt_text}`)}&description=${encodeURIComponent(buildLinearDescription(p))}`}
                target="_blank"
                rel="noopener"
              >Create Linear issue</a>

              <button
                type="button"
                class="share-btn share-btn-slack"
                data-clipboard-text={buildSlackText(p)}
                data-toast="Copied for Slack"
              >Copy for Slack</button>

              <a
                class="share-btn share-btn-pdf"
                href={`/downloads/content_briefs/${briefFilename(p)}`}
                download
              >Download brief (PDF)</a>

              <a
                class="share-btn share-btn-md"
                href={`/downloads/content_briefs/${briefFilename(p).replace(/\.pdf$/, '.md')}`}
                download
              >Download brief (Markdown)</a>
            </div>
          </div>

          <details class="raw-data-panel">
            <summary><span class="eyebrow">From the MCP</span><span class="raw-data-summary-label">Raw data for this prompt · click to expand</span></summary>
            <pre class="raw-data-json">{JSON.stringify({
              prompt_id: p.prompt_id,
              prompt_text: p.prompt_text,
              divergence_score: p.divergence_score,
              cv_visibility: p.cv_visibility,
              range_visibility: p.range_visibility,
              visibility_by_model: p.visibility_by_model,
              wilson_ci_by_model: p.wilson_ci_by_model,
              silence_type: p.silence_type,
              top_competitors: p.top_competitors,
              chat_sample: p.chat_sample
            }, null, 2)}</pre>
          </details>

          <div class="deepdive-columns">
            {active_models.map((m: any) => {
              const sample = p.chat_sample.by_model[m.id];
              const vis = p.visibility_by_model[m.id];
              const hasData = sample && sample.chat_id;
              const ci = (p.wilson_ci_by_model || {})[m.id];
              const lo = ci ? ci[0] : null;
              const hi = ci ? ci[1] : null;
              return (
                <div class={`deepdive-col${vis === 1 ? ' is-hero' : ''}${vis === 0 && hasData ? ' is-silent' : ''}${!hasData ? ' is-nodata' : ''}`}>
                  <div class="deepdive-col-head">
                    <span class="deepdive-engine">{m.name}</span>
                    <span class="deepdive-vis mono">{vis === null ? 'no data' : pct(vis) + '%'}</span>
                  </div>
                  {vis !== null && ci && (
                    <div class="deepdive-ci" title={`Wilson 95 % CI: ${(lo*100).toFixed(0)}% – ${(hi*100).toFixed(0)}%. N = 3 chats. Point estimate = ${pct(vis)}%.`}>
                      <div class="deepdive-ci-track">
                        <div class="deepdive-ci-band" style={`left: ${lo*100}%; width: ${(hi-lo)*100}%`}></div>
                        <div class="deepdive-ci-point" style={`left: ${vis*100}%`}></div>
                      </div>
                      <div class="deepdive-ci-label mono">CI 95 % · {(lo*100).toFixed(0)}–{(hi*100).toFixed(0)}% · N = 3</div>
                    </div>
                  )}
                  {sample?.note && <p class="sidenote" style="margin-top: 16px;">{sample.note}</p>}
                  {hasData && sample.brands_mentioned && sample.brands_mentioned.length > 0 && (
                    <div class="deepdive-brands">
                      <div class="eyebrow">Brands cited</div>
                      <div class="deepdive-brand-list">
                        {sample.brands_mentioned.map((b: any) => (
                          <span class={`brand-name ${b.name === own_brand ? 'is-own' : 'is-competitor'}`}>#{b.position} {b.name}</span>
                        ))}
                      </div>
                    </div>
                  )}
                  {hasData && (!sample.brands_mentioned || sample.brands_mentioned.length === 0) && (
                    <div class="deepdive-brands">
                      <div class="eyebrow">Brands cited</div>
                      <p class="text-mute" style="font-style: italic; margin-top: 8px; font-size: 14px;">– no tracked brand mentioned –</p>
                    </div>
                  )}
                  {hasData && sample.claims && sample.claims.length > 0 && (
                    <div class="deepdive-claims">
                      <div class="eyebrow">Extracted claims · top {sample.claims.length}</div>
                      <ul class="claim-list">
                        {sample.claims.map((c: any) => {
                          let brandClass = '';
                          if (c.type === 'brand') {
                            brandClass = ` claim-brand-${classifyBrandClaim(c.text)}`;
                          } else {
                            const hit = brandHitInClaim(c.text);
                            if (hit) brandClass = ` claim-brandhit-${hit}`;
                          }
                          return (
                            <li class={`claim claim-type-${c.type}${brandClass}`}>
                              <span class="claim-label">{c.type}</span>
                              <span class="claim-text">{c.text}</span>
                            </li>
                          );
                        })}
                      </ul>
                    </div>
                  )}
                  {hasData && sample.response_excerpt && (
                    <blockquote class="deepdive-quote">
                      {sample.response_excerpt}
                    </blockquote>
                  )}
                  {sample?.caveat && (
                    <p class="sidenote" style="margin-top: 12px; font-size: 13px; border-left-color: var(--drift); color: var(--drift);">{sample.caveat}</p>
                  )}
                </div>
              );
            })}
          </div>
          </div>
        </article>
      ))}

      {(remainingDrifting.length + remainingOwnOnly.length + remainingFull.length) > 0 && (
        <div class="mini-groups">
          <p class="caption mini-groups-lede">
